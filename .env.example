# Copy this file to .env and fill in the values.
# docker-compose and the Python server both load .env automatically.

# ── REQUIRED ────────────────────────────────────────────────────────────────

# API authentication key. In dev mode any non-empty string works.
# REQUIRED in production (SECA_ENV=prod); the server aborts startup if unset.
SECA_API_KEY=dev-key

# Runtime environment. Use "dev" locally, "prod" in production.
# "prod" enforces JWT auth and disables debug output.
SECA_ENV=dev

# Dev-mode auth bypass. When SECA_API_KEY is unset and SECA_ENV=dev, the
# server REJECTS unauthenticated requests with HTTP 401 by default — this
# closes the prod-misdeployment footgun where a SECA_ENV=dev that lands
# on a public host would otherwise serve protected endpoints openly.
# To explicitly opt into the bypass for local development, set this to
# "true". A loud warning lands in the startup log when the flag is on,
# and the dev_mode_no_flag rejection test in llm/tests/test_api_security.py
# pins the closed-by-default behaviour. NEVER set this in production.
# See docs/THREAT_MODEL.md § T6 for the full rationale.
# SECA_INSECURE_DEV=true

# JWT signing key. REQUIRED in production — must be a stable, secret value of
# at least 32 characters. In dev mode an ephemeral random key is generated
# automatically (all tokens are invalidated on restart).
# Generate a suitable value with: python -c "import secrets; print(secrets.token_hex(32))"
# SECRET_KEY=

# ── STOCKFISH ENGINE ─────────────────────────────────────────────────────────

# Path to the Stockfish binary. Leave unset to use auto-detection.
# The server checks PATH first (shutil.which), then falls back to the OS default.
#
#   Linux system install:  /usr/games/stockfish  or  /usr/bin/stockfish
#   macOS Homebrew:        /opt/homebrew/bin/stockfish
#   Windows:               engines/stockfish.exe  (place binary in project root)
#   Docker:                /usr/games/stockfish   (installed via apt at build time)
#
# STOCKFISH_PATH=

# ── DATABASE / STORAGE ───────────────────────────────────────────────────────

# SQLAlchemy connection URL.  Owns every auth / game / training /
# analytics table (the schema lives in llm/seca/storage/models.py and
# is built on the SQLAlchemy ``Base``; init_schema() runs idempotently
# at startup and adds new columns via _ensure_column helpers).
#
#   Dev / test default:  sqlite:///data/seca.db (file-backed, no setup)
#   Production:          postgresql://user:pass@host:5432/dbname
#
# When unset, the dev SQLite default is used — fine for local work but
# unsuitable for any environment where two processes can race.  Pinned
# by llm/tests/test_schema_boundary.py.
# DATABASE_URL=sqlite:///data/seca.db

# ── LLM / DEEPSEEK ───────────────────────────────────────────────────────────

# DeepSeek API key. REQUIRED for LLM coaching to work.  Sign up at
# https://platform.deepseek.com, create a key, paste it here.
#
# Without this set, the api still serves but every /chat call returns
# the deterministic-fallback template (chat_pipeline.py:557 catches the
# LLMConfigError and falls through).  GET /llm/health surfaces this as
# {"ok": false, "error": "COACH_DEEPSEEK_API_KEY is unset"} so you'll
# notice in monitoring rather than only in chat replies.
COACH_DEEPSEEK_API_KEY=

# DeepSeek API base URL.  Override only if you point at a self-hosted
# OpenAI-compatible gateway (LiteLLM, vLLM, Together, OpenAI proper).
# COACH_DEEPSEEK_API_BASE=https://api.deepseek.com

# DeepSeek model name.
#
# Default ``deepseek-chat`` is V3 — strong general-purpose model,
# $0.14/M input + $0.28/M output (current as of 2026-01).  Suitable
# for chess coaching prose (typical reply ~500 in / ~200 out tokens
# = ~$0.0001 per /chat call).
#
# Alternative: ``deepseek-reasoner`` for chain-of-thought reasoning
# (~4x cost, ~3x latency).  Probably overkill for explain-the-position
# prose; the Mode-2 prompt already grounds reasoning in the engine
# signal so reasoning-tier models don't add much value.
#
# This env value is passed verbatim to DeepSeek's /chat/completions
# ``model`` field; DeepSeek's docs list available models.
COACH_DEEPSEEK_MODEL=deepseek-chat

# ── CACHE (OPTIONAL) ─────────────────────────────────────────────────────────

# Redis URL for persistent move cache. Omit to use in-memory cache only.
# REDIS_URL=redis://localhost:6379

# ── SERVER ───────────────────────────────────────────────────────────────────

# HOST=0.0.0.0
# PORT=8000
# UVICORN_WORKERS=4

# Reverse-proxy trust list for per-client rate limiting.  Comma-separated
# IPs or CIDRs (IPv4 and IPv6 both accepted; bare IPs treated as /32 or /128).
#
#   Caddy on the same host:        127.0.0.0/8,::1/128
#   Docker bridge + Caddy host:    127.0.0.0/8,::1/128,172.16.0.0/12
#   Cloudflare in front of Caddy:  add Cloudflare's published CIDRs
#
# REQUIRED in production (SECA_ENV=prod) — when unset, X-Forwarded-For
# is never trusted and every request behind the proxy keys onto the
# same rate-limit bucket (a single attacker can saturate the
# /auth/login 10/min budget for everyone else).  A loud WARNING lands
# in the startup log when this happens; the dev default is loopback
# only.  Contract pinned by llm/tests/test_security_proxy_aware_limiter.py
# (TPA_01..TPA_14).
# TRUSTED_PROXIES=

# ── ENGINE PERFORMANCE (OPTIONAL OVERRIDES) ──────────────────────────────────

# ENGINE_POOL_SIZE=8
# ENGINE_THREADS=1
# ENGINE_HASH_MB=128
# ENGINE_SKILL_LEVEL=10
# ENGINE_DEFAULT_MOVETIME_MS=40
# ENGINE_BLITZ_MOVETIME_MS=25
# ENGINE_ANALYSIS_MOVETIME_MS=80

# Movetime budget for training endpoints (lesson / drill workflows).
# Floored at 20 ms by the engine wiring (values below are silently raised).
# ENGINE_TRAINING_MOVETIME_MS=40

# Queue-wait timeout before the engine pool fast-fails an incoming request.
# Floored at 1 ms.  Bound by THREAT_MODEL § T3 — raising this above ~200 ms
# lets pool backpressure leak into client latency, which is the DoS we want
# to prevent.  Pinned by llm/tests/test_doc_constants_pinned.py.
# ENGINE_QUEUE_TIMEOUT_MS=50

# Optional cache-busting override for the move cache. The cache key
# automatically incorporates a fingerprint of the engine config (skill
# level, threads, movetimes, Stockfish binary path), so changing those
# fields already invalidates stale entries. Set ENGINE_CACHE_VERSION to
# any string to force a flush WITHOUT changing those fields — useful
# when you replace the Stockfish binary in place at the same path. Bump
# the value (e.g. "post-upgrade-2026-05") to land in a fresh cache
# namespace; old entries TTL out without being served.
# ENGINE_CACHE_VERSION=

# ── OBSERVABILITY SHIPPING (Sprint 5.D.3, OPTIONAL) ──────────────────────────
#
# Grafana Alloy ships JSON structured logs (5.D.2) and Prometheus metrics
# (5.D.1) from the Hetzner backend to Grafana Cloud's free tier.  None of
# these are required to run the API — the default deploy excludes Alloy
# from the active compose services.  Set the five values below AND start
# the monitoring profile to enable shipping:
#
#     docker compose --profile monitoring up -d alloy
#
# How to get the values:
#
#   1. Create a free Grafana Cloud account at https://grafana.com/products/cloud/
#      (the free tier covers 50 GB logs + Prometheus metrics + 14-day
#      retention; no credit card required).
#   2. In Grafana Cloud, open "Connections → Data Sources".  Note the
#      pre-provisioned ``grafanacloud-<stack>-logs`` (Loki) and
#      ``grafanacloud-<stack>-prom`` (Prometheus) entries.
#   3. The ``URL`` field on each data source is the push endpoint.  Strip
#      the ``/loki/api/v1/push`` or ``/api/prom/push`` path off if the
#      page shows the read endpoint instead — the push URL is documented
#      under "Send data" on the same screen.
#   4. The numeric ``User`` field is the Grafana Cloud instance ID
#      (separate for Loki and Prometheus on the multi-tenant stack).
#   5. Generate ONE API key at "Account → API Keys" with both
#      ``logs:write`` AND ``metrics:write`` scopes.  Save it; Grafana
#      doesn't show it again.
#
# Without these vars set, ``docker compose --profile monitoring up`` will
# refuse to start the alloy service (SECA_API_KEY is required for the
# /metrics scrape and Alloy's basic_auth aborts if the password env is
# unset).  The api / db / redis / caddy services run fine without any
# of these — observability is purely additive.

# Loki push endpoint, e.g. https://logs-prod-006.grafana.net/loki/api/v1/push
# GRAFANA_CLOUD_LOKI_URL=

# Numeric Loki instance ID from the Grafana Cloud "Data Sources" page.
# GRAFANA_CLOUD_LOKI_USER=

# Prometheus push endpoint, e.g.
# https://prometheus-prod-37-prod-eu-west-2.grafana.net/api/prom/push
# GRAFANA_CLOUD_PROM_URL=

# Numeric Prometheus instance ID.  Usually DIFFERENT from the Loki
# instance ID — copy carefully from the data-source pages.
# GRAFANA_CLOUD_PROM_USER=

# Single API key with logs:write + metrics:write scopes.  Same value
# is used as the basic_auth password for both Loki and Prometheus
# push (Grafana Cloud's multi-tenant ingest is keyed on a single
# user-level token, not separate tokens per data source).
# GRAFANA_CLOUD_API_KEY=

# ── LOGGING / TELEMETRY (LOCAL TOGGLES) ──────────────────────────────────────

# Force JSON-formatted log output regardless of SECA_ENV.  Useful when
# piping local dev logs into a structured viewer (jq, Vector, etc.)
# without flipping SECA_ENV=prod (which would also enable prod auth).
#
#   Unset / empty / "0" / "false":  text format in dev, JSON in prod
#   "1" / "true" / "yes":           JSON in all environments
#
# Contract pinned by llm/tests/test_log_config.py (LOG_06, LOG_07).
# COACH_LOG_JSON=

# Per-request timeout (seconds) for the LLM call inside GET /llm/health.
# A wedged DeepSeek call cannot block the healthcheck longer than this;
# the route returns {"ok": false} on timeout so monitoring catches the
# stall.  Do not set below ~5 seconds in production — a normal DeepSeek
# round-trip can take 2-3 seconds under load.
# LLM_HEALTH_GENERATE_TIMEOUT_S=10

# RAG telemetry sink (in-memory retrieval / validator counters used by
# the regression harness).  Set to "0" to disable for performance-
# sensitive load tests; any other value (including unset) enables the
# sink at its default ring-buffer size.
# LLM_TELEMETRY=1

# ── LICHESS IMPORT (OPTIONAL) ────────────────────────────────────────────────
#
# The /lichess/import endpoint fetches a user's recent Lichess games
# and ingests them into the analytics pipeline.  Anonymous access works
# for public games; an OAuth token unlocks higher rate limits and
# access to ongoing-game streams.
#
# Generate a token at https://lichess.org/account/oauth/token with the
# minimum scope required by your flow (most just need ``preference:read``
# + ``email:read``).  Never commit the token.

# Lichess API base URL.  Override only for staging mirrors.
# LICHESS_API_BASE=https://lichess.org

# OAuth bearer token for higher-rate-limit Lichess access.  Optional;
# omit for anonymous import of public games.
# LICHESS_OAUTH_TOKEN=

# User-Agent header sent with every Lichess request.  Lichess asks
# integrations to identify themselves for abuse triage.
# LICHESS_USER_AGENT=ChessCoach/1.0 (lichess-import)

# ── SAFETY & FREEZE GUARDS (DO NOT TOGGLE IN PROD) ───────────────────────────
#
# These flags exist for local development of the dormant adaptive-RL
# code paths (Project Rule 3: autonomous RL implementation is
# prohibited).  Production must run with the adaptive layer LOCKED.
# The freeze guard hard-crashes startup if either flag is loosened
# while SECA_ENV=prod.  Pinned by llm/tests/test_safety_freeze.py and
# llm/tests/test_seca_status.py.

# SAFE_MODE switch.  Defaults to "true" (locked).  Recognised disable
# values: "false", "0", "no" (case-insensitive).  Any other value —
# including typos — resolves to "true": the failure mode is always
# "stay safe", never "silently unlock".  In SECA_ENV=prod,
# SECA_SAFE_MODE=false triggers sys.exit(1) at startup
# (llm/seca/safety/freeze.py::_assert_safe_mode_locked).  In dev/test,
# "false" is allowed but logs a loud startup warning.
# SECA_SAFE_MODE=true

# Online-learning trip-wire.  Setting "1" enables the dormant online-
# learning trainer in events/router.py and learning/trainer.py — but
# the freeze guard rejects this in prod (and even in dev unless brain
# freezes have been explicitly bypassed).  Treat as a tripwire, not a
# feature flag.
# SECA_ENABLE_ONLINE_LEARNING=

# ── EXPERIMENTAL: COACH SELECTION ────────────────────────────────────────────

# Enable the contextual-bandit coach for event-mode coach selection.
# When "1", llm/seca/events/router.py uses the bandit policy to pick
# the coaching variant; otherwise the deterministic default is used.
# Off in all environments by default — feature-flagged because the
# bandit's exploration arm trades determinism for adaptation on the
# user-visible coaching surface.  Pinned by
# llm/tests/test_bandit_integration.py.
# SECA_USE_BANDIT_COACH=

# ── ENTITLEMENTS (FREEMIUM TIERS) ────────────────────────────────────────────

# Master switch for free/Pro usage limits (llm/seca/entitlements).
# Defaults to OFF: unset, empty, or unrecognised values all resolve to
# "no metering" — the failure posture is "stay free", never "start
# rejecting traffic".  Recognised enable values: "true", "1", "yes"
# (case-insensitive).  Keep OFF in production until the Android
# client-reaction release (paywall sheet + degrade chip) has shipped;
# until then free users would see raw 402s instead of an upgrade
# surface.  Limits live in llm/seca/entitlements/service.py::LIMITS.
# SECA_ENTITLEMENTS_ENFORCED=
