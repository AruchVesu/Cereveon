# Copy this file to .env and fill in the values.
# docker-compose and the Python server both load .env automatically.

# ── REQUIRED ────────────────────────────────────────────────────────────────

# API authentication key. In dev mode any non-empty string works.
# REQUIRED in production (SECA_ENV=prod); the server aborts startup if unset.
SECA_API_KEY=dev-key

# Runtime environment. Use "dev" locally, "prod" in production.
# "prod" enforces JWT auth and disables debug output.
SECA_ENV=dev

# Dev-mode auth bypass. When SECA_API_KEY is unset and SECA_ENV=dev, the
# server REJECTS unauthenticated requests with HTTP 401 by default — this
# closes the prod-misdeployment footgun where a SECA_ENV=dev that lands
# on a public host would otherwise serve protected endpoints openly.
# To explicitly opt into the bypass for local development, set this to
# "true". A loud warning lands in the startup log when the flag is on,
# and the dev_mode_no_flag rejection test in llm/tests/test_api_security.py
# pins the closed-by-default behaviour. NEVER set this in production.
# See docs/THREAT_MODEL.md § T6 for the full rationale.
# SECA_INSECURE_DEV=true

# JWT signing key. REQUIRED in production — must be a stable, secret value of
# at least 32 characters. In dev mode an ephemeral random key is generated
# automatically (all tokens are invalidated on restart).
# Generate a suitable value with: python -c "import secrets; print(secrets.token_hex(32))"
# SECRET_KEY=

# ── STOCKFISH ENGINE ─────────────────────────────────────────────────────────

# Path to the Stockfish binary. Leave unset to use auto-detection.
# The server checks PATH first (shutil.which), then falls back to the OS default.
#
#   Linux system install:  /usr/games/stockfish  or  /usr/bin/stockfish
#   macOS Homebrew:        /opt/homebrew/bin/stockfish
#   Windows:               engines/stockfish.exe  (place binary in project root)
#   Docker:                /usr/games/stockfish   (installed via apt at build time)
#
# STOCKFISH_PATH=

# ── LLM / DEEPSEEK ───────────────────────────────────────────────────────────

# DeepSeek API key. REQUIRED for LLM coaching to work.  Sign up at
# https://platform.deepseek.com, create a key, paste it here.
#
# Without this set, the api still serves but every /chat call returns
# the deterministic-fallback template (chat_pipeline.py:557 catches the
# LLMConfigError and falls through).  GET /llm/health surfaces this as
# {"ok": false, "error": "COACH_DEEPSEEK_API_KEY is unset"} so you'll
# notice in monitoring rather than only in chat replies.
COACH_DEEPSEEK_API_KEY=

# DeepSeek API base URL.  Override only if you point at a self-hosted
# OpenAI-compatible gateway (LiteLLM, vLLM, Together, OpenAI proper).
# COACH_DEEPSEEK_API_BASE=https://api.deepseek.com

# DeepSeek model name.
#
# Default ``deepseek-chat`` is V3 — strong general-purpose model,
# $0.14/M input + $0.28/M output (current as of 2026-01).  Suitable
# for chess coaching prose (typical reply ~500 in / ~200 out tokens
# = ~$0.0001 per /chat call).
#
# Alternative: ``deepseek-reasoner`` for chain-of-thought reasoning
# (~4x cost, ~3x latency).  Probably overkill for explain-the-position
# prose; the Mode-2 prompt already grounds reasoning in the engine
# signal so reasoning-tier models don't add much value.
#
# This env value is passed verbatim to DeepSeek's /chat/completions
# ``model`` field; DeepSeek's docs list available models.
COACH_DEEPSEEK_MODEL=deepseek-chat

# ── CACHE (OPTIONAL) ─────────────────────────────────────────────────────────

# Redis URL for persistent move cache. Omit to use in-memory cache only.
# REDIS_URL=redis://localhost:6379

# ── SERVER ───────────────────────────────────────────────────────────────────

# HOST=0.0.0.0
# PORT=8000
# UVICORN_WORKERS=4

# ── ENGINE PERFORMANCE (OPTIONAL OVERRIDES) ──────────────────────────────────

# ENGINE_POOL_SIZE=8
# ENGINE_THREADS=1
# ENGINE_HASH_MB=128
# ENGINE_SKILL_LEVEL=10
# ENGINE_DEFAULT_MOVETIME_MS=40
# ENGINE_BLITZ_MOVETIME_MS=25
# ENGINE_ANALYSIS_MOVETIME_MS=80

# Optional cache-busting override for the move cache. The cache key
# automatically incorporates a fingerprint of the engine config (skill
# level, threads, movetimes, Stockfish binary path), so changing those
# fields already invalidates stale entries. Set ENGINE_CACHE_VERSION to
# any string to force a flush WITHOUT changing those fields — useful
# when you replace the Stockfish binary in place at the same path. Bump
# the value (e.g. "post-upgrade-2026-05") to land in a fresh cache
# namespace; old entries TTL out without being served.
# ENGINE_CACHE_VERSION=
