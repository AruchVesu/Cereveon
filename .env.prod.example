# =============================================================================
# .env.prod.example — Production server environment template
# =============================================================================
# Copy to .env.prod on your Hetzner server and fill in every CHANGE_ME value.
#
#   cp .env.prod.example .env.prod
#   chmod 600 .env.prod
#
# Variables managed by Docker Compose or shell (not this file):
#   COACH_OLLAMA_URL  — set in docker-compose.prod.yml environment: block
#   REDIS_URL         — set in docker-compose.prod.yml environment: block
#   DOMAIN            — exported in the shell before running compose
#   GHCR_IMAGE        — exported in the shell / set by CI via DEPLOY_IMAGE
# =============================================================================

# ── Runtime mode (required) ──────────────────────────────────────────────────
SECA_ENV=prod

# ── API authentication (required) ────────────────────────────────────────────
# Generate: openssl rand -hex 32
SECA_API_KEY=CHANGE_ME

# ── Session / JWT secret (required, >= 32 chars) ─────────────────────────────
# Generate: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_ME

# ── CORS (required) ──────────────────────────────────────────────────────────
# Comma-separated list of allowed origins (no trailing slash).
CORS_ALLOWED_ORIGINS=https://cereveon.com

# ── Database (required) ──────────────────────────────────────────────────────
DATABASE_URL=postgresql://chesscoach:CHANGE_ME@db:5432/chesscoach
POSTGRES_DB=chesscoach
POSTGRES_USER=chesscoach
POSTGRES_PASSWORD=CHANGE_ME

# ── Optional overrides ───────────────────────────────────────────────────────
# STOCKFISH_PATH=/usr/games/stockfish
#
# Production model pin. Tags can be re-pushed; pin the digest so a rotation
# upstream cannot silently change behaviour under the LLM regression
# contract. Find the current digest with:
#
#     docker compose -f docker-compose.prod.yml exec ollama \
#         ollama show qwen2.5:7b-instruct-q2_K --modelfile | grep '^FROM'
#
# Then paste the resulting `model:tag@sha256:<hex>` reference below.
# COACH_OLLAMA_MODEL=qwen2.5:7b-instruct-q2_K@sha256:CHANGE_ME
#
# UVICORN_WORKERS=2
