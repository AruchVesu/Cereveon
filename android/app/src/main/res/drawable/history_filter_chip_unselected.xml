<?xml version="1.0" encoding="utf-8"?>
<!--
    Unselected history-filter chip — transparent fill, faint hairline
    border so the chip shape reads without competing with the selected
    one.  Hard edges.
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <solid android:color="@android:color/transparent" />
    <stroke
        android:width="1dp"
        android:color="@color/atrium_hairline" />
</shape>
