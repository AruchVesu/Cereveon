<?xml version="1.0" encoding="utf-8"?>
<!-- Default plan tile — hairline border, transparent fill.  Used for
     the unselected plan in the 2-column grid. -->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <solid android:color="@android:color/transparent" />
    <stroke
        android:width="1dp"
        android:color="@color/atrium_hairline" />
</shape>
