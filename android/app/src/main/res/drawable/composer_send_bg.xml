<?xml version="1.0" encoding="utf-8"?>
<!--
    Atrium composer send button — 32×32 square, cyan border at full
    accent, transparent fill so the arrow glyph carries the colour.
    Pressed state lights the fill at 13% accent for tap feedback.
-->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <stroke
                android:width="@dimen/atrium_hairline_thickness"
                android:color="@color/atrium_accent_cyan" />
            <solid android:color="@color/atrium_accent_cyan_22" />
            <corners android:radius="@dimen/atrium_corner_radius" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <stroke
                android:width="@dimen/atrium_hairline_thickness"
                android:color="@color/atrium_accent_cyan" />
            <solid android:color="@android:color/transparent" />
            <corners android:radius="@dimen/atrium_corner_radius" />
        </shape>
    </item>
</selector>
