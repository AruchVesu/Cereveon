<?xml version="1.0" encoding="utf-8"?>
<!--
    Atrium secondary button — quieter than primary.  Hairline-strong
    border (12% white), transparent fill, square 2dp radius.  Used for
    the 44×44 "?" / "←" / "⋯" icon buttons next to a primary action.
-->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <stroke
                android:width="@dimen/atrium_hairline_thickness"
                android:color="@color/atrium_ink" />
            <solid android:color="@color/atrium_hairline" />
            <corners android:radius="@dimen/atrium_corner_radius" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <stroke
                android:width="@dimen/atrium_hairline_thickness"
                android:color="@color/atrium_hairline_strong" />
            <solid android:color="@android:color/transparent" />
            <corners android:radius="@dimen/atrium_corner_radius" />
        </shape>
    </item>
</selector>
