<?xml version="1.0" encoding="utf-8"?>
<!--
    Default opening-card background — transparent fill, hairline border.
    Used for entries the user has not committed to as their main repertoire.
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <solid android:color="@android:color/transparent" />
    <stroke
        android:width="1dp"
        android:color="@color/atrium_hairline" />
</shape>
