<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!--
      SECA safe-mode gate strings.  See:
        - llm/seca/shared_limiter.py  (server-side counterpart)
        - SecaSafetyGate.kt           (client gate)
        - MainActivity.observeSafetyGate
    -->
    <string name="seca_safety_checking">Checking backend safety…</string>
    <string name="seca_safety_unsafe">Backend safety unverified: %1$s. Coaching disabled.</string>
    <string name="seca_safety_chat_blocked">Coaching unavailable until the backend safety check passes. Tap Retry on the safety banner.</string>
    <string name="seca_safety_retry">Retry</string>

    <!--
      In-game drawer "Exit to Home" affordance.  See MainActivity.btnExitToHome
      wiring; finishes the activity so the back-stack pops to HomeActivity.
    -->
    <string name="game_exit_to_home">Exit to Home</string>

    <!--
      In-game drawer account / app actions.  btnSignOut routes through the
      shared AccountFlows.performLogout (same flow as the Settings sheet's
      Account row); btnSendFeedback opens FeedbackFlows' dialog form, which
      POSTs to /feedback (docs/API_CONTRACTS.md §38).
    -->
    <string name="game_sign_out">Sign out</string>
    <string name="game_send_feedback">Send feedback</string>

    <!--
      Reset-game confirmation dialog (MainActivity.btnReset).  Reset wipes
      the in-progress game irreversibly, so the tap is gated behind an
      explicit "Are you sure" confirm; GamePanelActionsSourcePinTest pins
      that the destructive path only runs from the dialog's positive button.
    -->
    <string name="reset_confirm_title">Reset game?</string>
    <string name="reset_confirm_message">Are you sure you want to reset the game? Your current progress will be lost.</string>
    <string name="reset_confirm_positive">Reset</string>
    <string name="reset_confirm_negative">Cancel</string>

    <!--
      Delete-account confirmation dialog (AccountFlows.confirmAndDeleteAccount;
      GDPR Art. 17, DELETE /auth/me — docs/API_CONTRACTS.md §41).  Deletion is
      irreversible and erases everything server-side, so the tap is gated
      behind the same explicit "Are you sure" idiom as Reset game;
      SettingsDeleteAccountSourcePinTest pins that the destructive path only
      runs from the dialog's positive button.
    -->
    <string name="delete_account_confirm_title">Delete account?</string>
    <string name="delete_account_confirm_message">Are you sure? This permanently deletes your account and everything in it — games, chat history, progress, study plans and imported Lichess games. This cannot be undone.</string>
    <string name="delete_account_confirm_positive">Delete</string>
    <string name="delete_account_confirm_negative">Cancel</string>

    <!-- Send-feedback dialog form (FeedbackFlows.kt). -->
    <string name="feedback_dialog_title">Send feedback</string>
    <string name="feedback_input_hint">What\'s working? What\'s broken? We read every message.</string>
    <string name="feedback_send">Send</string>
    <string name="feedback_cancel">Cancel</string>
    <string name="feedback_empty_error">Please write a short message first.</string>
    <string name="feedback_sent">Thanks — your feedback was sent.</string>
    <string name="feedback_send_failed">Couldn\'t send feedback. Please check your connection and try again.</string>

    <!--
      Lichess Connect bottom sheet (LichessConnectBottomSheet.kt).
      Mirrors docs/API_CONTRACTS.md §§27–30 wording where user-facing.
    -->
    <string name="lichess_connect_intro">Link your Lichess account to import your game history. We use your matching perf rating (rapid first, then blitz, then classical) to seed your in-app rating on first link.</string>
    <string name="lichess_username_hint">Lichess username</string>
    <string name="lichess_link_button_label">Link Lichess account</string>
    <string name="lichess_linked_as_kicker">Linked as</string>
    <string name="lichess_imported_label">Imported games</string>
    <string name="lichess_last_synced_label">Last sync</string>
    <string name="lichess_never_synced">Never</string>
    <string name="lichess_import_button_label">Import games</string>
    <string name="lichess_unlink_button_label">Unlink Lichess</string>

    <!-- Calibration banner — shown once on the post-link transition.
         The numeric rating used to lead this line ("Rating set to 1645
         from your Lichess ...") but was dropped when the user-visible
         Elo display was hidden from the UI.  The calibrated rating is
         still applied internally and continues to drive adaptive
         opponent matching — we just no longer expose the number. -->
    <string name="lichess_calibration_banner">Calibrated from your Lichess %1$s (%2$d games).</string>
    <string name="lichess_calibration_banner_provisional">Calibrated from your Lichess %1$s (%2$d games, provisional).</string>

    <!-- Import-completion toasts. -->
    <string name="lichess_import_summary_inserted">Imported %1$d games</string>
    <string name="lichess_import_summary_all_duplicates">Already imported · %1$d games skipped as duplicates</string>
    <string name="lichess_import_summary_empty">No new games to import</string>

    <!-- Determinate import progress caption (v2 async path).
         %1$d = inserted so far, %2$d = target cap (max_games).
         "_with_skipped" appends skipped-game count when non-zero so
         the user sees why total != target on completion. -->
    <string name="lichess_import_progress_caption">Imported %1$d of up to %2$d</string>
    <string name="lichess_import_progress_caption_with_skipped">Imported %1$d of up to %2$d · %3$d skipped</string>

    <!-- Error toasts and inline messages. -->
    <string name="lichess_error_unauthenticated">Sign in required</string>
    <string name="lichess_error_username_invalid">Use 2–30 letters, digits, underscores, or hyphens.</string>
    <string name="lichess_error_username_not_found">Lichess user not found</string>
    <string name="lichess_error_already_linked">This Lichess account is already linked to another player</string>
    <string name="lichess_error_not_linked">No Lichess account linked yet</string>
    <string name="lichess_error_rate_limited">Lichess is rate-limiting requests · try again in a moment</string>
    <string name="lichess_error_upstream">Lichess is unreachable · try again shortly</string>
    <string name="lichess_error_network">Network error · check your connection</string>
    <string name="lichess_error_timeout">Request timed out · try again</string>
    <string name="lichess_error_unknown">Something went wrong · try again</string>

    <!-- Reconnect state (API_CONTRACTS §29 `disconnected`): the linked
         Lichess account 404'd on import — closed or renamed.  The
         notice sits above the re-link form inside the Connect sheet;
         copy adapted from communication & access spec §2.6. -->
    <string name="lichess_reconnect_notice">We lost access to your Lichess account. This can happen if it was closed or renamed. Your imported games and reviews stay here — reconnect the same account once it\'s back, or connect a different one below.</string>
    <string name="lichess_reconnect_button_label">Reconnect Lichess</string>

    <!--
      Notifications feed (NotificationsBottomSheet.kt + Home header
      bell).  Mirrors docs/API_CONTRACTS.md §40 wording where
      user-facing.
    -->
    <string name="notifications_bell_cd">Notifications</string>
    <string name="notifications_dismiss_cd">Dismiss notification</string>
    <string name="notifications_mark_all_read">MARK ALL READ</string>
    <string name="notifications_section_unread">UNREAD (%1$d)</string>
    <string name="notifications_section_read">READ</string>
    <string name="notifications_empty">Nothing here yet. Game reviews and account notices will land in this inbox.</string>
    <string name="notifications_error">Could not load notifications. Check your connection.</string>
</resources>
