<?xml version="1.0" encoding="utf-8"?>
<!--
    Network security configuration.

    Release: cleartext traffic is forbidden globally — all connections must use TLS.
    Debug:   cleartext is permitted only to the Android emulator host (10.0.2.2) and
             localhost so the app can reach the dev backend over plain HTTP.
             User-added CA certificates are also trusted in debug builds.

    TLS certificate pinning (release path): see the <pin-set> on the
    cereveon.com domain-config below.  Closes the THREAT_MODEL.md § T2
    residual where a system-store MITM CA could terminate HTTPS to
    cereveon.com cleanly.  See docs/CERT_PIN_ROTATION.md for the
    rotation procedure.
-->
<network-security-config>

    <!-- Base policy: TLS required everywhere, system CAs only. -->
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>

    <!--
        Production API hostname.  TLS is enforced via the base-config above;
        the pin-set narrows trust further by requiring the cert chain to
        match one of three SPKI hashes.

        Three pins covers the realistic rotation surface:
          YE1      — current Let's Encrypt ECDSA intermediate (the leaf's
                     direct issuer).  Matches today's chain
                     (leaf → YE1 → ISRG Root YE → ISRG Root X2 → X1).
          ISRG X1  — RSA root, valid until 2030.  Survives YE1 rotation
                     to a sibling LE intermediate that still chains to X1.
          ISRG X2  — ECDSA root, valid until 2035.  The served chain
                     currently terminates here (cross-signed by X1), so
                     this root pin is what keeps matching as the
                     intermediate rotates.

        ``expiration`` is the graceful-fallback floor: if pins aren't
        rotated by that date and the chain has drifted in some way the
        three roots above don't cover, NetworkSecurityConfig falls back
        to system-CA trust (same posture as before this pin set landed).
        That's deliberate — bricking the app on a missed rotation would
        be worse than the pre-pinning posture.

        Rotation procedure: docs/CERT_PIN_ROTATION.md.
        Source-pin test: NetworkSecurityCertPinningTest.kt.
    -->
    <domain-config>
        <domain includeSubdomains="true">cereveon.com</domain>
        <pin-set expiration="2028-05-20">
            <!-- Let's Encrypt YE1 ECDSA intermediate (the current leaf's direct issuer). -->
            <pin digest="SHA-256">brzvtCELCIZUo4sD/qPX0ccRtPsd3DY6RfmxpOU9oB4=</pin>
            <!-- ISRG Root X1 (RSA root, valid until 2030). -->
            <pin digest="SHA-256">C5+lpZ7tcVwmwQIMcRtPbsQtWLABXhQzejna0wHFr8M=</pin>
            <!-- ISRG Root X2 (ECDSA root, valid until 2035) — backup. -->
            <pin digest="SHA-256">diGVwiVYbubAI3RW4hB9xU8e/CH2GnkuvVFZE8zmgzI=</pin>
        </pin-set>
    </domain-config>

    <!--
        Cleartext is permitted to the Android emulator host and localhost so the
        app can reach the dev backend over plain HTTP. Applies to all build types;
        release builds connect to https:// cereveon.com only and never use these hosts.
        Kept at the top level because <debug-overrides> does not allow child
        <domain-config> elements (NetworkSecurityConfig lint rule).
    -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="false">10.0.2.2</domain>
        <domain includeSubdomains="false">localhost</domain>
    </domain-config>

    <!--
        Debug overrides: trust user-installed CAs (Charles, mitmproxy, etc.).
        Stripped from release builds by the build toolchain.
    -->
    <debug-overrides>
        <trust-anchors>
            <certificates src="system" />
            <certificates src="user" />
        </trust-anchors>
    </debug-overrides>

</network-security-config>
