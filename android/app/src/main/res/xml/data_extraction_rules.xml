<?xml version="1.0" encoding="utf-8"?>
<!--
   Data extraction rules (Android 12+ / API 31+).

   chesscoach_prefs.xml holds plaintext game state (board FEN, UCI move
   history, the pending /game/finish PGN payload, rating/confidence).  Exclude
   it from both cloud backup and device-to-device transfer so it never leaves
   the device in the clear.  allowBackup="false" already disables Auto Backup;
   this additionally closes the Android-12+ device-transfer path.  The JWT is
   held in a separate EncryptedSharedPreferences store (Keystore-backed).
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="sharedpref" path="chesscoach_prefs.xml" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="sharedpref" path="chesscoach_prefs.xml" />
    </device-transfer>
</data-extraction-rules>
