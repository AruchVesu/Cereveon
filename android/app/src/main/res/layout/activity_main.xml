<?xml version="1.0" encoding="utf-8"?>
<!--
    Cereveon · Atrium · In-game coaching (Variation B).

    Top → bottom:
      1. Chapter header (kicker + italic title + ✦ rule)
      2. Opponent rail (amber dot + name + ELO + clock)
      3. Board on raised mat
      4. Player rail (cyan dot + "You" + ELO + clock)
      5. Eval band (5-step coarse signal — no numeric eval, ever)
      6. Coach paragraph (italic Cormorant prose)
      7. Footer kickers (theme + band)
      8. Action bar ("Ask the coach" + "?")

    Every original view ID from the pre-Atrium layout is preserved so
    MainActivity.kt's findViewById wiring and the existing
    MainActivityWeaknessTest / ChessViewModelTest fixtures keep working
    with no Kotlin-side changes.  IDs that simply move to a different
    parent: chessBoard, drawerLayout, txtCoach, txtCoachContainer,
    statusPulse, scoreRow, txtEngineScore, txtMistakeCategory,
    txtRatingHeader, txtWeaknessTags, txtNextTrainingChip, btnReset,
    btnUndo, btnChat, btnGameHistory, btnProgressDashboard, btnTraining,
    btnChangePassword, btnLogout.

    New IDs added (no MainActivity wiring required to stay functional;
    activity may opt-in to populate them):
      atriumChapterHeader, opponentName, opponentElo, opponentClock,
      playerName, playerElo, playerClock, evalBand, btnAskCoach, btnHelp.
-->
<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/drawerLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- ─── MAIN ─────────────────────────────────────────────────────── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- Chapter header — Atrium kicker + title + ✦ rule. -->
        <ai.chesscoach.app.AtriumChapterHeaderView
            android:id="@+id/atriumChapterHeader"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:atriumKicker="Chapter · Move"
            app:atriumTitle="Position" />

        <!-- Opponent rail. -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="@dimen/atrium_space_20"
            android:paddingEnd="@dimen/atrium_space_20"
            android:paddingTop="@dimen/atrium_space_8"
            android:paddingBottom="@dimen/atrium_space_8">

            <View
                android:layout_width="6dp"
                android:layout_height="6dp"
                android:layout_marginEnd="@dimen/atrium_space_8"
                android:background="@drawable/rail_dot_amber" />

            <TextView
                android:id="@+id/opponentName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textAppearance="@style/Atrium.Body.Italic"
                android:textSize="15sp"
                android:text="Opponent" />

            <TextView
                android:id="@+id/opponentElo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/atrium_space_8"
                android:textAppearance="@style/Atrium.Kicker"
                android:text="1680" />

            <Space
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1" />

            <TextView
                android:id="@+id/opponentClock"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textAppearance="@style/Atrium.Numeric.Amber"
                android:text="14:03" />

        </LinearLayout>

        <!-- Board on a raised mat. -->
        <FrameLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginStart="@dimen/atrium_space_16"
            android:layout_marginEnd="@dimen/atrium_space_16"
            android:padding="@dimen/atrium_space_8"
            android:background="@drawable/board_mat_atrium"
            android:elevation="6dp">

            <ai.chesscoach.app.ChessBoardView
                android:id="@+id/chessBoard"
                android:layout_width="332dp"
                android:layout_height="332dp" />

        </FrameLayout>

        <!-- Player rail. -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="@dimen/atrium_space_20"
            android:paddingEnd="@dimen/atrium_space_20"
            android:paddingTop="@dimen/atrium_space_8"
            android:paddingBottom="@dimen/atrium_space_8">

            <View
                android:layout_width="6dp"
                android:layout_height="6dp"
                android:layout_marginEnd="@dimen/atrium_space_8"
                android:background="@drawable/rail_dot_cyan" />

            <TextView
                android:id="@+id/playerName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textAppearance="@style/Atrium.Body.Italic"
                android:textSize="15sp"
                android:text="You" />

            <TextView
                android:id="@+id/playerElo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/atrium_space_8"
                android:textAppearance="@style/Atrium.Kicker"
                android:text="1720 · white" />

            <Space
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1" />

            <TextView
                android:id="@+id/playerClock"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textAppearance="@style/Atrium.Numeric.Cyan"
                android:text="14:21" />

        </LinearLayout>

        <!-- Eval band — 5-step coarse signal, no numeric eval. -->
        <ai.chesscoach.app.EvalBandView
            android:id="@+id/evalBand"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/atrium_space_24"
            android:layout_marginEnd="@dimen/atrium_space_24"
            android:layout_marginTop="@dimen/atrium_space_4"
            android:layout_marginBottom="@dimen/atrium_space_12"
            app:atriumBand="equal"
            app:atriumSide="white" />

        <!--
            Coach paragraph block.  Original txtCoachContainer / txtCoach /
            statusPulse / scoreRow / txtEngineScore / txtMistakeCategory /
            txtNextTrainingChip IDs live here so MainActivity.kt's
            findViewById calls and the existing tests keep working.
        -->
        <LinearLayout
            android:id="@+id/txtCoachContainer"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="vertical"
            android:paddingStart="@dimen/atrium_space_24"
            android:paddingEnd="@dimen/atrium_space_24"
            android:paddingTop="@dimen/atrium_space_4"
            android:paddingBottom="@dimen/atrium_space_8">

            <!-- Optional next-training chip; activity toggles visibility. -->
            <TextView
                android:id="@+id/txtNextTrainingChip"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textAppearance="@style/Atrium.Kicker.Cyan"
                android:paddingStart="@dimen/atrium_space_8"
                android:paddingEnd="@dimen/atrium_space_8"
                android:paddingTop="2dp"
                android:paddingBottom="2dp"
                android:layout_marginBottom="@dimen/atrium_space_8"
                android:background="@color/atrium_bg_surface"
                android:visibility="gone"
                tools:text="NEXT · TACTICS · 12 MIN"
                tools:visibility="visible" />

            <!-- Coach prose row: small status pulse + Cormorant body. -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="top">

                <View
                    android:id="@+id/statusPulse"
                    android:layout_width="6dp"
                    android:layout_height="6dp"
                    android:layout_marginTop="9dp"
                    android:layout_marginEnd="@dimen/atrium_space_8"
                    android:background="@drawable/status_dot_green" />

                <TextView
                    android:id="@+id/txtCoach"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textAppearance="@style/Atrium.Body"
                    android:text="Ready"
                    tools:text="Notice how your pieces are working together here — the bishop on g5 quietly constrains Black's knight, and the central pawn holds the space you've been building toward." />

            </LinearLayout>

            <!--
                Footer divider + kicker row.  Reuses the original
                scoreRow / txtMistakeCategory / txtEngineScore IDs:
                txtMistakeCategory takes the THEME · X kicker slot
                (left), txtEngineScore takes the BAND · Y slot
                (right, accent cyan).  Activity flips visibility from
                gone → visible after the first AI move, same as before.
            -->
            <View
                android:layout_width="match_parent"
                android:layout_height="@dimen/atrium_hairline_thickness"
                android:layout_marginTop="@dimen/atrium_space_12"
                android:background="@color/atrium_hairline" />

            <LinearLayout
                android:id="@+id/scoreRow"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingTop="@dimen/atrium_space_8"
                android:visibility="gone"
                tools:visibility="visible">

                <TextView
                    android:id="@+id/txtMistakeCategory"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textAppearance="@style/Atrium.Kicker"
                    tools:text="Theme · pin" />

                <Space
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1" />

                <TextView
                    android:id="@+id/txtEngineScore"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textAppearance="@style/Atrium.Kicker.Cyan"
                    tools:text="Band · better" />

            </LinearLayout>

        </LinearLayout>

        <!--
            Action bar — primary "Ask the coach" + 44dp square help.
            New IDs (btnAskCoach, btnHelp) are unwired today; the
            activity can opt-in by adding setOnClickListener calls —
            "Ask the coach" naturally fans out to the same chat flow
            the drawer's existing btnChat opens.
        -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="@dimen/atrium_space_16"
            android:paddingEnd="@dimen/atrium_space_16"
            android:paddingBottom="@dimen/atrium_space_16"
            android:paddingTop="@dimen/atrium_space_8">

            <Button
                android:id="@+id/btnAskCoach"
                style="@style/Atrium.Button.Primary"
                android:layout_width="0dp"
                android:layout_height="@dimen/atrium_tap_target"
                android:layout_weight="1"
                android:layout_marginEnd="@dimen/atrium_space_8"
                android:text="Ask the coach" />

            <Button
                android:id="@+id/btnHelp"
                style="@style/Atrium.Button.Secondary"
                android:layout_width="@dimen/atrium_tap_target"
                android:layout_height="@dimen/atrium_tap_target"
                android:padding="0dp"
                android:text="?" />

        </LinearLayout>

    </LinearLayout>

    <!-- ─── DRAWER (sidebar) ──────────────────────────────────────────── -->
    <!--
        Drawer left intentionally close to the original — re-skinned by
        the theme cascade (Material3 button colours + Atrium tokens
        flow in automatically), but layout structure unchanged so the
        existing button wiring keeps working.  A focused drawer
        redesign is its own follow-up commit.
    -->
    <LinearLayout
        android:layout_width="280dp"
        android:layout_height="match_parent"
        android:layout_gravity="end"
        android:orientation="vertical"
        android:background="@color/atrium_bg_surface"
        android:paddingTop="@dimen/atrium_space_20"
        android:paddingStart="@dimen/atrium_space_20"
        android:paddingEnd="@dimen/atrium_space_20"
        android:paddingBottom="@dimen/atrium_space_44">

        <TextView
            android:id="@+id/txtRatingHeader"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textAppearance="@style/Atrium.Numeric.Cyan"
            android:text="Rating: —"
            android:paddingBottom="@dimen/atrium_space_4" />

        <TextView
            android:id="@+id/txtWeaknessTags"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textAppearance="@style/Atrium.Kicker"
            android:paddingBottom="@dimen/atrium_space_12"
            android:visibility="gone" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textAppearance="@style/Atrium.Kicker"
            android:text="GAME OPTIONS"
            android:paddingBottom="@dimen/atrium_space_16" />

        <Button
            android:id="@+id/btnReset"
            style="@style/Atrium.Button.Secondary"
            android:layout_width="match_parent"
            android:layout_height="@dimen/atrium_tap_target"
            android:textSize="16sp"
            android:text="Reset game"
            android:layout_marginBottom="@dimen/atrium_space_8" />

        <Button
            android:id="@+id/btnUndo"
            style="@style/Atrium.Button.Secondary"
            android:layout_width="match_parent"
            android:layout_height="@dimen/atrium_tap_target"
            android:textSize="16sp"
            android:text="Undo move" />

        <View
            style="@style/Atrium.Divider"
            android:layout_marginTop="@dimen/atrium_space_24"
            android:layout_marginBottom="@dimen/atrium_space_24" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textAppearance="@style/Atrium.Kicker"
            android:text="AI ASSISTANCE"
            android:paddingBottom="@dimen/atrium_space_16" />

        <Button
            android:id="@+id/btnChat"
            style="@style/Atrium.Button.Primary"
            android:layout_width="match_parent"
            android:layout_height="@dimen/atrium_tap_target"
            android:text="Open coach chat"
            android:layout_marginBottom="@dimen/atrium_space_8" />

        <Button
            android:id="@+id/btnGameHistory"
            style="@style/Atrium.Button.Secondary"
            android:layout_width="match_parent"
            android:layout_height="@dimen/atrium_tap_target"
            android:textSize="16sp"
            android:text="Game history"
            android:layout_marginBottom="@dimen/atrium_space_8" />

        <Button
            android:id="@+id/btnProgressDashboard"
            style="@style/Atrium.Button.Secondary"
            android:layout_width="match_parent"
            android:layout_height="@dimen/atrium_tap_target"
            android:textSize="16sp"
            android:text="My progress"
            android:layout_marginBottom="@dimen/atrium_space_8" />

        <Button
            android:id="@+id/btnTraining"
            style="@style/Atrium.Button.Secondary"
            android:layout_width="match_parent"
            android:layout_height="@dimen/atrium_tap_target"
            android:textSize="16sp"
            android:text="Training session"
            android:layout_marginBottom="@dimen/atrium_space_8" />

        <Button
            android:id="@+id/btnSettings"
            style="@style/Atrium.Button.Secondary"
            android:layout_width="match_parent"
            android:layout_height="@dimen/atrium_tap_target"
            android:textSize="16sp"
            android:text="Settings" />

        <View
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <Button
            android:id="@+id/btnChangePassword"
            style="@style/Atrium.Button.Secondary"
            android:layout_width="match_parent"
            android:layout_height="@dimen/atrium_tap_target"
            android:textSize="14sp"
            android:text="Change password"
            android:layout_marginBottom="@dimen/atrium_space_8" />

        <Button
            android:id="@+id/btnLogout"
            style="@style/Atrium.Button.Secondary"
            android:layout_width="match_parent"
            android:layout_height="@dimen/atrium_tap_target"
            android:textSize="14sp"
            android:text="Sign out"
            android:textColor="@color/atrium_accent_amber"
            android:layout_marginBottom="@dimen/atrium_space_8" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textAppearance="@style/Atrium.Kicker"
            android:text="CHESS ENGINE V1.0"
            android:gravity="center"
            android:paddingTop="@dimen/atrium_space_16" />

    </LinearLayout>

</androidx.drawerlayout.widget.DrawerLayout>
