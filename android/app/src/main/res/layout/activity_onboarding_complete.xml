<?xml version="1.0" encoding="utf-8"?>
<!--
    Cereveon · Atrium · Onboarding · Completion (handoff step 3 of 3).

    Final screen of the post-registration flow.  Reads back the
    calibration the user just supplied (rating + confidence + first
    opponent) so they see what's been recorded before the first game,
    then sends them to HomeActivity on tap.

    Top → bottom:
      1.  Centered cyan kicker "CEREVEON · STEP 3 OF 3"
      2.  Italic display title "Ready when you are."
      3.  ✦ ornament rule
      4.  Summary card — accent-cyan border, 3 rows:
            Rating   · {value}
            Confidence · {label}
            First opponent · ~{value}
      5.  Footer — single primary "Play your first game" button
-->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_atrium_gradient"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:paddingStart="@dimen/atrium_space_24"
        android:paddingEnd="@dimen/atrium_space_24"
        android:paddingTop="@dimen/atrium_space_44"
        android:paddingBottom="@dimen/atrium_space_24">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/atrium_space_32"
            android:textAppearance="@style/Atrium.Kicker.Cyan"
            android:text="Cereveon · Step 3 of 3" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/atrium_space_12"
            android:fontFamily="@font/cormorant_garamond"
            android:textStyle="italic"
            android:textColor="@color/atrium_ink"
            android:textSize="36sp"
            android:lineSpacingMultiplier="1.05"
            android:gravity="center_horizontal"
            android:text="Ready when you are." />

        <!-- ✦ ornament rule. -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/atrium_space_24"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <View
                android:layout_width="0dp"
                android:layout_height="@dimen/atrium_hairline_thickness"
                android:layout_weight="1"
                android:background="@color/atrium_hairline_strong" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/atrium_space_8"
                android:layout_marginEnd="@dimen/atrium_space_8"
                android:fontFamily="@font/cormorant_garamond"
                android:textColor="@color/atrium_muted"
                android:textSize="14sp"
                android:text="✦" />

            <View
                android:layout_width="0dp"
                android:layout_height="@dimen/atrium_hairline_thickness"
                android:layout_weight="1"
                android:background="@color/atrium_hairline_strong" />

        </LinearLayout>

        <!-- Summary card — same accent-cyan-bordered surface as the
             paywall's active plan tile, used here to frame what was
             just calibrated. -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="@dimen/atrium_space_24"
            android:padding="@dimen/atrium_space_16"
            android:background="@drawable/atrium_paywall_plan_active">

            <!-- Rating row. -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:baselineAligned="false">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textAppearance="@style/Atrium.Kicker"
                    android:text="Rating" />

                <TextView
                    android:id="@+id/onboardingCompleteRating"
                    android:fontFamily="@font/cormorant_garamond"
                    android:textStyle="italic"
                    android:textColor="@color/atrium_accent_cyan"
                    android:textSize="22sp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="—"
                    tools:text="1720" />

            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="@dimen/atrium_hairline_thickness"
                android:layout_marginTop="@dimen/atrium_space_8"
                android:layout_marginBottom="@dimen/atrium_space_8"
                android:background="@color/atrium_hairline" />

            <!-- Confidence row. -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:baselineAligned="false">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textAppearance="@style/Atrium.Kicker"
                    android:text="Confidence" />

                <TextView
                    android:id="@+id/onboardingCompleteConfidence"
                    android:fontFamily="@font/cormorant_garamond"
                    android:textStyle="italic"
                    android:textColor="@color/atrium_ink"
                    android:textSize="17sp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="—"
                    tools:text="Sure of it" />

            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="@dimen/atrium_hairline_thickness"
                android:layout_marginTop="@dimen/atrium_space_8"
                android:layout_marginBottom="@dimen/atrium_space_8"
                android:background="@color/atrium_hairline" />

            <!-- First opponent row. -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:baselineAligned="false">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textAppearance="@style/Atrium.Kicker"
                    android:text="First opponent" />

                <TextView
                    android:id="@+id/onboardingCompleteOpponent"
                    android:fontFamily="@font/cormorant_garamond"
                    android:textStyle="italic"
                    android:textColor="@color/atrium_accent_amber"
                    android:textSize="17sp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="—"
                    tools:text="~1680 · adaptive" />

            </LinearLayout>

        </LinearLayout>

        <Space
            android:layout_width="match_parent"
            android:layout_height="@dimen/atrium_space_32" />

        <Button
            android:id="@+id/btnOnboardingCompleteStart"
            style="@style/Atrium.Button.Primary"
            android:layout_width="match_parent"
            android:layout_height="@dimen/atrium_tap_target"
            android:text="Play your first game" />

    </LinearLayout>

</ScrollView>
