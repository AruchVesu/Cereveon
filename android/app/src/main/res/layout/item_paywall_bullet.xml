<?xml version="1.0" encoding="utf-8"?>
<!--
    Single ✦-bulleted feature row used in activity_paywall's
    paywallFeatures container.  Cyan ✦ ornament + a vertical text column:
    the italic Cormorant ink feature line, and an optional muted
    "Free plan: …" contrast line under it — shown only for metered
    features via PaywallActivity.renderFeatureBullets.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:paddingTop="@dimen/atrium_space_8"
    android:paddingBottom="@dimen/atrium_space_8">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="@font/cormorant_garamond"
        android:textStyle="italic"
        android:textSize="16sp"
        android:textColor="@color/atrium_accent_cyan"
        android:text="✦" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:layout_marginStart="@dimen/atrium_space_12"
        android:orientation="vertical">

        <TextView
            android:id="@+id/paywallBulletText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="@font/cormorant_garamond"
            android:textSize="16sp"
            android:textColor="@color/atrium_ink"
            android:text="—"
            tools:text="Unlimited adaptive games" />

        <!-- Optional Free-plan contrast; visibility toggled in code. -->
        <TextView
            android:id="@+id/paywallBulletFree"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/atrium_space_4"
            android:fontFamily="@font/inter"
            android:textSize="12sp"
            android:textColor="@color/atrium_dim"
            android:visibility="gone"
            tools:visibility="visible"
            tools:text="Free plan: 1 a day" />

    </LinearLayout>

</LinearLayout>
