<?xml version="1.0" encoding="utf-8"?>
<!--
    Cereveon · Atrium · Home / Library (handoff screen #5).

    Post-auth landing replacing direct routing into MainActivity.  Users
    arrive here from LoginActivity (or OnboardingActivity for first-run)
    and pick what they want to do next.

    Top → bottom:
      1.  Header — wordmark + circular avatar (initials); tapping the
          avatar opens the Settings sheet over this activity.
      2.  Date kicker — "<weekday> · Day <N>" (N = days since registration
          or some other monotonic counter; we currently fake it with the
          local date so the surface ships before backend support lands).
      3.  Italic Cormorant display — "Continue your study."
      4.  ✦ ornament rule.
      5.  Resume card — last in-progress game (HIDDEN until we have a
          last-game persistence hook in MainActivity).
      6.  Library section header.
      7.  2 library rows — Roman numeral · italic title · italic muted
          sub · ›:
            I — New game     (→ MainActivity)
            II — Past games  (→ MainActivity + EXTRA_OPEN_SHEET=history)
      8.  Bottom tab bar — Home (active) / Puzzles / You.  Puzzles opens
          the study-plan overview sheet, You opens the progress dashboard
          sheet — both hosted directly over HomeActivity (no MainActivity
          relaunch); tab navigation as a true root is a separate effort.
-->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_atrium_gradient">

    <!-- Scrollable content above the bottom tab bar. -->
    <ScrollView
        android:id="@+id/homeScroll"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@+id/homeTabBar">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="@dimen/atrium_space_24"
            android:paddingEnd="@dimen/atrium_space_24"
            android:paddingTop="@dimen/atrium_space_24"
            android:paddingBottom="@dimen/atrium_space_24">

            <!-- Header — wordmark + avatar. -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:baselineAligned="false">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:fontFamily="@font/cormorant_garamond"
                    android:textStyle="italic"
                    android:textColor="@color/atrium_ink"
                    android:textSize="22sp"
                    android:letterSpacing="0.018"
                    android:text="Cereveon" />

                <!-- Notification bell — opens the feed sheet.  Same
                     48dp-target / smaller-visual pattern as the avatar
                     beside it.  The badge dot renders the unread count
                     (server-computed, medium+ priority) and hides at
                     zero. -->
                <FrameLayout
                    android:id="@+id/homeBellTapTarget"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:contentDescription="@string/notifications_bell_cd"
                    android:background="?attr/selectableItemBackgroundBorderless">

                    <ImageView
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:layout_gravity="center"
                        android:importantForAccessibility="no"
                        android:src="@drawable/ic_bell"
                        app:tint="@color/atrium_muted" />

                    <TextView
                        android:id="@+id/homeBellBadge"
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:layout_gravity="top|end"
                        android:layout_marginTop="6dp"
                        android:layout_marginEnd="6dp"
                        android:gravity="center"
                        android:background="@drawable/bell_badge_bg"
                        android:fontFamily="monospace"
                        android:textSize="9sp"
                        android:textColor="@color/atrium_bg_base"
                        android:visibility="gone"
                        tools:visibility="visible"
                        tools:text="3" />

                </FrameLayout>

                <!-- The avatar doubles as the Settings entry point (the
                     only other route is the in-game drawer, which
                     requires starting a game first).  The 48dp
                     FrameLayout is the accessible touch target; the
                     32dp circle stays the visual.  The negative end
                     margin re-flushes the circle with the content
                     column's 24dp edge, cancelling the target's
                     8dp overhang. -->
                <FrameLayout
                    android:id="@+id/homeAvatarTapTarget"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_marginEnd="-8dp"
                    android:contentDescription="Settings"
                    android:background="?attr/selectableItemBackgroundBorderless">

                    <TextView
                        android:id="@+id/homeAvatar"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:layout_gravity="center"
                        android:gravity="center"
                        android:fontFamily="@font/cormorant_garamond"
                        android:textStyle="italic"
                        android:textColor="@color/atrium_accent_cyan"
                        android:textSize="14sp"
                        android:background="@drawable/atrium_home_avatar"
                        android:text="—"
                        tools:text="AG" />

                </FrameLayout>

            </LinearLayout>

            <!-- Date kicker. -->
            <TextView
                android:id="@+id/homeDateKicker"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/atrium_space_16"
                android:textAppearance="@style/Atrium.Kicker"
                android:text="—"
                tools:text="Tuesday · Day 047" />

            <!-- Training XP / Level kicker — replaces the legacy Elo
                 rating display.  Wired in HomeActivity.onCreate: reads
                 cached PREF_TRAINING_XP for instant display, then fires
                 GET /auth/me to refresh.  Hidden until the first
                 successful /auth/me populates the cache.  Cyan accent
                 keeps the role assignment of the previous Elo kicker
                 (player-side anchor on this screen, mirroring
                 AtriumChapterHeaderView / EvalBandView).  The id is
                 retained — only the displayed text changes — so test
                 hooks and existing findViewById callers keep working. -->
            <TextView
                android:id="@+id/homePersonalRating"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/atrium_space_4"
                android:textAppearance="@style/Atrium.Kicker"
                android:textColor="@color/atrium_accent_cyan"
                android:text="—"
                android:visibility="gone"
                tools:visibility="visible"
                tools:text="Level 1 · 0 XP" />

            <!--
                Pending-sync indicator — surfaces an unsynced
                /game/finish payload that's waiting in prefs.  Amber to
                read as "attention needed" without escalating to error
                red.  Hidden by default; shown by HomeActivity when
                PendingGameFinish.PREF_PENDING_FINISH_PAYLOAD is set,
                hidden after a successful background retry.
            -->
            <LinearLayout
                android:id="@+id/homeSyncIndicator"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/atrium_space_4"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:visibility="gone"
                tools:visibility="visible">

                <View
                    android:layout_width="6dp"
                    android:layout_height="6dp"
                    android:layout_marginEnd="@dimen/atrium_space_8"
                    android:background="@drawable/rail_dot_amber" />

                <TextView
                    android:id="@+id/homeSyncIndicatorText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/jetbrains_mono"
                    android:textSize="9sp"
                    android:letterSpacing="0.222"
                    android:textAllCaps="true"
                    android:textColor="@color/atrium_accent_amber"
                    android:text="1 game pending sync"
                    tools:text="1 game pending sync" />

            </LinearLayout>

            <!-- Italic display title. -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/atrium_space_4"
                android:fontFamily="@font/cormorant_garamond"
                android:textStyle="italic"
                android:textColor="@color/atrium_ink"
                android:textSize="30sp"
                android:lineSpacingMultiplier="1.1"
                android:text="Continue your study." />

            <!-- ✦ ornament rule. -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/atrium_space_12"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <View
                    android:layout_width="0dp"
                    android:layout_height="@dimen/atrium_hairline_thickness"
                    android:layout_weight="1"
                    android:background="@color/atrium_hairline_strong" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/atrium_space_8"
                    android:layout_marginEnd="@dimen/atrium_space_8"
                    android:fontFamily="@font/cormorant_garamond"
                    android:textColor="@color/atrium_muted"
                    android:textSize="14sp"
                    android:text="✦" />

                <View
                    android:layout_width="0dp"
                    android:layout_height="@dimen/atrium_hairline_thickness"
                    android:layout_weight="1"
                    android:background="@color/atrium_hairline_strong" />

            </LinearLayout>

            <!-- Resume card — hidden until last-game state is available. -->
            <LinearLayout
                android:id="@+id/homeResumeBlock"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="@dimen/atrium_space_24"
                android:visibility="gone"
                tools:visibility="visible">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textAppearance="@style/Atrium.Kicker"
                    android:text="Resume" />

                <LinearLayout
                    android:id="@+id/homeResumeCard"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/atrium_space_8"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="@drawable/atrium_home_resume_bg"
                    android:padding="@dimen/atrium_space_12"
                    android:clickable="true"
                    android:focusable="true">

                    <View
                        android:layout_width="56dp"
                        android:layout_height="56dp"
                        android:background="@drawable/board_mat_atrium" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="@dimen/atrium_space_12"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/homeResumeTitle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/cormorant_garamond"
                            android:textStyle="italic"
                            android:textColor="@color/atrium_ink"
                            android:textSize="17sp"
                            android:text="—"
                            tools:text="Game 047 · move 14" />

                        <TextView
                            android:id="@+id/homeResumeSub"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/atrium_space_4"
                            android:textAppearance="@style/Atrium.Kicker"
                            android:text="—"
                            tools:text="vs. adaptive · your move" />

                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/cormorant_garamond"
                        android:textStyle="italic"
                        android:textColor="@color/atrium_accent_cyan"
                        android:textSize="22sp"
                        android:text="→" />

                </LinearLayout>

            </LinearLayout>

            <!-- Today's drill card (study-plan phase 4).
                 Surfaces the player's most recent active per-mistake study
                 plan + the puzzle currently due, when /coach/plan/today
                 returns a non-null body with a non-null today_puzzle.
                 HIDDEN by default; HomeActivity.onResume calls
                 GameApiClient.getCoachPlanToday() and toggles visibility +
                 populates the kicker / verdict / day indicator. -->
            <LinearLayout
                android:id="@+id/homeTodaysDrillBlock"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="@dimen/atrium_space_24"
                android:visibility="gone"
                tools:visibility="visible">

                <TextView
                    android:id="@+id/homeTodaysDrillKicker"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textAppearance="@style/Atrium.Kicker"
                    android:text="Today's drill"
                    tools:text="Today's drill · Day 1 of 3" />

                <LinearLayout
                    android:id="@+id/homeTodaysDrillCard"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/atrium_space_8"
                    android:orientation="vertical"
                    android:background="@drawable/atrium_home_resume_bg"
                    android:padding="@dimen/atrium_space_16"
                    android:clickable="true"
                    android:focusable="true">

                    <TextView
                        android:id="@+id/homeTodaysDrillTheme"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/cormorant_garamond"
                        android:textStyle="italic"
                        android:textColor="@color/atrium_accent_cyan"
                        android:textSize="17sp"
                        android:text="—"
                        tools:text="Practice · King safety" />

                    <TextView
                        android:id="@+id/homeTodaysDrillVerdict"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/atrium_space_8"
                        android:textColor="@color/atrium_ink"
                        android:textSize="14sp"
                        android:lineSpacingMultiplier="1.25"
                        android:maxLines="4"
                        android:ellipsize="end"
                        android:text=""
                        tools:text="Bringing the king toward the centre with pieces still on the board exposes it to a quick attack; the resulting tempo loss let your opponent build pressure faster than you could defend." />

                    <Button
                        android:id="@+id/homeTodaysDrillStartButton"
                        style="@style/Atrium.Button.Primary"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/atrium_space_16"
                        android:text="Start drill" />

                </LinearLayout>

            </LinearLayout>

            <!-- Library section. -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/atrium_space_24"
                android:textAppearance="@style/Atrium.Kicker"
                android:text="Library" />

            <!-- Library row — I — New game. -->
            <LinearLayout
                android:id="@+id/homeRowNewGame"
                style="@style/Atrium.HomeLibraryRow"
                android:tag="newgame">

                <TextView
                    style="@style/Atrium.HomeLibraryRow.Numeral"
                    android:text="I" />

                <LinearLayout
                    style="@style/Atrium.HomeLibraryRow.TitleBlock">

                    <TextView
                        style="@style/Atrium.HomeLibraryRow.Title"
                        android:text="New game" />

                    <TextView
                        android:id="@+id/homeRowNewGameSub"
                        style="@style/Atrium.HomeLibraryRow.Sub"
                        android:text="Adaptive opponent"
                        tools:text="Adaptive opponent" />

                </LinearLayout>

                <TextView style="@style/Atrium.HomeLibraryRow.Chevron" />

            </LinearLayout>

            <View
                style="@style/Atrium.HomeLibraryRow.Divider" />

            <!-- Library row — II — Past games. -->
            <LinearLayout
                android:id="@+id/homeRowPastGames"
                style="@style/Atrium.HomeLibraryRow"
                android:tag="history">

                <TextView
                    style="@style/Atrium.HomeLibraryRow.Numeral"
                    android:text="II" />

                <LinearLayout
                    style="@style/Atrium.HomeLibraryRow.TitleBlock">

                    <TextView
                        style="@style/Atrium.HomeLibraryRow.Title"
                        android:text="Past games" />

                    <TextView
                        android:id="@+id/homeRowPastGamesSub"
                        style="@style/Atrium.HomeLibraryRow.Sub"
                        android:text="Recent activity"
                        tools:text="46 played · 27 won" />

                </LinearLayout>

                <TextView style="@style/Atrium.HomeLibraryRow.Chevron" />

            </LinearLayout>

        </LinearLayout>

    </ScrollView>

    <!-- Bottom tab bar — Home active. -->
    <LinearLayout
        android:id="@+id/homeTabBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingTop="@dimen/atrium_space_12"
        android:paddingBottom="@dimen/atrium_space_16"
        android:paddingStart="@dimen/atrium_space_24"
        android:paddingEnd="@dimen/atrium_space_24"
        android:background="@color/atrium_bg_base"
        app:layout_constraintBottom_toBottomOf="parent">

        <View
            android:layout_width="0dp"
            android:layout_height="@dimen/atrium_hairline_thickness"
            android:layout_weight="0"
            android:visibility="gone" />

        <LinearLayout
            android:id="@+id/homeTabHome"
            style="@style/Atrium.HomeTab"
            android:tag="home">

            <TextView
                style="@style/Atrium.HomeTab.Label.Active"
                android:text="Home" />

            <View
                style="@style/Atrium.HomeTab.Dot" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/homeTabPuzzles"
            style="@style/Atrium.HomeTab"
            android:tag="puzzles">

            <TextView
                style="@style/Atrium.HomeTab.Label"
                android:text="Puzzles" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/homeTabYou"
            style="@style/Atrium.HomeTab"
            android:tag="you">

            <TextView
                style="@style/Atrium.HomeTab.Label"
                android:text="You" />

        </LinearLayout>

    </LinearLayout>

    <!-- Hairline above tab bar. -->
    <View
        android:layout_width="match_parent"
        android:layout_height="@dimen/atrium_hairline_thickness"
        android:background="@color/atrium_hairline"
        app:layout_constraintBottom_toTopOf="@+id/homeTabBar" />

</androidx.constraintlayout.widget.ConstraintLayout>
