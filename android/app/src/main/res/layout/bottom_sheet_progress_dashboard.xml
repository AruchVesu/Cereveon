<?xml version="1.0" encoding="utf-8"?>
<!--
    Cereveon · Atrium · Profile / stats (screen #9 in the handoff).

    Top → bottom:
      1.  Drag handle.
      2.  Chapter header — "PROFILE" / "Your trends".
      3.  Hero cell — "Level N" display + "X XP" kicker, from the
          cached training XP (hidden until the cache exists).
      4.  Stat row — "Recent games · N played · M won", from the
          /player/progress history window (hidden until fetch succeeds).
      5.  STRONGEST SIDES section — kicker + WeaknessBarChartView (per-category strengths).
          Atrium uses italic chips for "patterns" (handoff #9), but
          the existing bar chart is more informative — kept and
          re-skinned via the foundation theme cascade rather than
          reduced to chips.
      6.  HOW THE COACH SEES YOU section — kicker +
          worldModelContainer (activity inflates content into it).
      7.  TRAINING FOCUS section — kicker + recommendationsList,
          with txtNoRecommendations empty state.
      8.  txtDashboardError shown when the dashboard fetch fails.

    Repurposed / retired Elo sections.
    The hero cell and stat row were originally the Elo rating +
    confidence surfaces, retired when the user-visible rating was
    hidden from the UI.  They are repurposed in place (same IDs —
    txtRating now renders "Level N", txtConfidence renders
    "N played · M won") as the profile's human-progress header.  The
    "Rating trend" sparkline section stays fully retired with
    ``visibility="gone"`` and is never flipped visible in code —
    plotting rating history would re-leak the hidden Elo, and there is
    no historical XP series to plot yet.  Its views stay in the tree
    as the slot for a future XP-trend visualisation.  The opponent-Elo
    row inside the world-model container is suppressed in code
    (``populateWorldModel`` filters it out).
-->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_atrium_gradient"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="@dimen/atrium_space_44">

        <!-- Drag handle. -->
        <View
            android:layout_width="40dp"
            android:layout_height="3dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="@dimen/atrium_space_8"
            android:layout_marginBottom="@dimen/atrium_space_8"
            android:background="@color/atrium_hairline_strong" />

        <!-- Chapter header. -->
        <ai.chesscoach.app.AtriumChapterHeaderView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:atriumKicker="Profile"
            app:atriumTitle="Your trends" />

        <!-- Hero level + XP kicker (human progress).  Originally the
             Elo hero cell; repurposed in place — txtRating keeps its
             id (XML↔Kotlin contract unchanged) but now renders
             "Level N" from the cached training XP.  Starts gone;
             ProgressDashboardBottomSheet flips it visible when the
             PREF_TRAINING_XP cache exists. -->
        <LinearLayout
            android:id="@+id/heroLevelBlock"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="@dimen/atrium_space_24"
            android:paddingEnd="@dimen/atrium_space_24"
            android:paddingTop="@dimen/atrium_space_8"
            android:visibility="gone"
            tools:visibility="visible">

            <TextView
                android:id="@+id/txtRating"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textAppearance="@style/Atrium.Display.Large"
                android:text="—"
                tools:text="Level 4" />

            <TextView
                android:id="@+id/txtHeroXp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/atrium_space_4"
                android:textAppearance="@style/Atrium.Kicker"
                android:text="—"
                tools:text="340 XP" />

        </LinearLayout>

        <!-- Recent-games stat row (human progress).  Originally the
             Elo confidence row; repurposed in place — txtConfidence
             keeps its id but now renders "N played · M won" from the
             /player/progress history window.  Starts gone;
             ProgressDashboardBottomSheet flips it visible when the
             fetch succeeds. -->
        <LinearLayout
            android:id="@+id/statGamesRow"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="@dimen/atrium_space_24"
            android:paddingEnd="@dimen/atrium_space_24"
            android:paddingTop="@dimen/atrium_space_12"
            android:visibility="gone"
            tools:visibility="visible">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textAppearance="@style/Atrium.Kicker"
                android:text="Recent games · " />

            <TextView
                android:id="@+id/txtConfidence"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textAppearance="@style/Atrium.Numeric.Cyan"
                android:text="—"
                tools:text="12 played · 7 won" />

        </LinearLayout>

        <!-- Divider between the stat row and the STRONGEST SIDES
             block (the "Rating trend" section in between stays gone).
             Starts gone and is flipped visible together with
             statGamesRow so an orphan hairline never floats above
             STRONGEST SIDES when the fetch fails. -->
        <View
            android:id="@+id/statGamesDivider"
            android:layout_width="match_parent"
            android:layout_height="@dimen/atrium_hairline_thickness"
            android:layout_marginStart="@dimen/atrium_space_24"
            android:layout_marginEnd="@dimen/atrium_space_24"
            android:layout_marginTop="@dimen/atrium_space_16"
            android:layout_marginBottom="@dimen/atrium_space_16"
            android:background="@color/atrium_hairline"
            android:visibility="gone" />

        <!-- RATING TREND.  Entire section retired when the
             user-visible Elo display was hidden; nothing in code
             touches these views any more (see header comment) — they
             stay in the tree as the slot for a future XP-trend
             visualisation. -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textAppearance="@style/Atrium.Kicker"
            android:text="Rating trend"
            android:paddingStart="@dimen/atrium_space_24"
            android:paddingEnd="@dimen/atrium_space_24"
            android:paddingBottom="@dimen/atrium_space_4"
            android:visibility="gone" />

        <ai.chesscoach.app.RatingSparklineView
            android:id="@+id/progressSparkline"
            android:layout_width="match_parent"
            android:layout_height="72dp"
            android:layout_marginStart="@dimen/atrium_space_24"
            android:layout_marginEnd="@dimen/atrium_space_24"
            android:layout_marginBottom="@dimen/atrium_space_8"
            android:visibility="gone"
            tools:visibility="gone" />

        <TextView
            android:id="@+id/txtNoRatingHistory"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textAppearance="@style/Atrium.Inline"
            android:textStyle="italic"
            android:textColor="@color/atrium_dim"
            android:text="Play more games to see your rating trend."
            android:paddingStart="@dimen/atrium_space_24"
            android:paddingEnd="@dimen/atrium_space_24"
            android:paddingBottom="@dimen/atrium_space_8"
            android:visibility="gone" />

        <View
            android:layout_width="match_parent"
            android:layout_height="@dimen/atrium_hairline_thickness"
            android:layout_marginStart="@dimen/atrium_space_24"
            android:layout_marginEnd="@dimen/atrium_space_24"
            android:layout_marginTop="@dimen/atrium_space_12"
            android:layout_marginBottom="@dimen/atrium_space_16"
            android:background="@color/atrium_hairline"
            android:visibility="gone" />

        <!-- STRONGEST SIDES — per-category strengths (inverse of the weakness
             rates), strongest first; built in ProgressDashboardBottomSheet. -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textAppearance="@style/Atrium.Kicker"
            android:text="Strongest sides"
            android:paddingStart="@dimen/atrium_space_24"
            android:paddingEnd="@dimen/atrium_space_24"
            android:paddingBottom="@dimen/atrium_space_8" />

        <ai.chesscoach.app.WeaknessBarChartView
            android:id="@+id/weaknessChart"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/atrium_space_20"
            android:layout_marginEnd="@dimen/atrium_space_20"
            android:minHeight="56dp" />

        <View
            android:layout_width="match_parent"
            android:layout_height="@dimen/atrium_hairline_thickness"
            android:layout_marginStart="@dimen/atrium_space_24"
            android:layout_marginEnd="@dimen/atrium_space_24"
            android:layout_marginTop="@dimen/atrium_space_16"
            android:layout_marginBottom="@dimen/atrium_space_16"
            android:background="@color/atrium_hairline" />

        <!-- HOW THE COACH SEES YOU. -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textAppearance="@style/Atrium.Kicker"
            android:text="How the coach sees you"
            android:paddingStart="@dimen/atrium_space_24"
            android:paddingEnd="@dimen/atrium_space_24"
            android:paddingBottom="@dimen/atrium_space_8" />

        <LinearLayout
            android:id="@+id/worldModelContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="@dimen/atrium_space_24"
            android:paddingEnd="@dimen/atrium_space_24" />

        <View
            android:layout_width="match_parent"
            android:layout_height="@dimen/atrium_hairline_thickness"
            android:layout_marginStart="@dimen/atrium_space_24"
            android:layout_marginEnd="@dimen/atrium_space_24"
            android:layout_marginTop="@dimen/atrium_space_16"
            android:layout_marginBottom="@dimen/atrium_space_16"
            android:background="@color/atrium_hairline" />

        <!-- COACH'S PLAN.

             Reads SharedPreferences keys populated by
             GameSummaryBottomSheet on every /game/finish:
               PREF_LAST_COACH_ACTION_TYPE
               PREF_LAST_COACH_WEAKNESS
               PREF_LAST_COACH_REASON
               PREF_LAST_COACH_TITLE
               PREF_LAST_COACH_DESCRIPTION
             Hidden when no game has been played yet (action type
             absent or "NONE" with empty reason).  The whole
             ``coachPlanCard`` toggles visibility together so the
             section doesn't render as a half-empty stub. -->
        <TextView
            android:id="@+id/txtCoachPlanKicker"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textAppearance="@style/Atrium.Kicker"
            android:text="Coach's plan"
            android:paddingStart="@dimen/atrium_space_24"
            android:paddingEnd="@dimen/atrium_space_24"
            android:paddingBottom="@dimen/atrium_space_8"
            android:visibility="gone" />

        <ai.chesscoach.app.AtriumCardView
            android:id="@+id/coachPlanCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="@dimen/atrium_space_16"
            android:layout_marginStart="@dimen/atrium_space_24"
            android:layout_marginEnd="@dimen/atrium_space_24"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- Action verdict + weakness focus area, both mono kickers. -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingBottom="@dimen/atrium_space_8">

                    <TextView
                        android:id="@+id/txtCoachPlanAction"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:textAppearance="@style/Atrium.Kicker"
                        android:textColor="@color/atrium_accent_cyan"
                        tools:text="PLAN UPDATE" />

                    <TextView
                        android:id="@+id/txtCoachPlanWeakness"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textAppearance="@style/Atrium.Kicker"
                        android:textColor="@color/atrium_dim"
                        tools:text="FOCUS · OPENING" />
                </LinearLayout>

                <!-- Headline copy from coach_content.title. -->
                <TextView
                    android:id="@+id/txtCoachPlanTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textAppearance="@style/Atrium.Body.Italic"
                    android:paddingBottom="@dimen/atrium_space_8"
                    tools:text="Structural change needed for your opening" />

                <!-- Prose from coach_content.description. -->
                <TextView
                    android:id="@+id/txtCoachPlanDescription"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textAppearance="@style/Atrium.Inline"
                    android:textColor="@color/atrium_muted"
                    android:paddingBottom="@dimen/atrium_space_8"
                    tools:text="You've been making the same kind of opening mistake across recent games. Focus your training time on opening principles before drilling other areas." />

                <!-- Reason (rationale from the controller's decision). -->
                <TextView
                    android:id="@+id/txtCoachPlanReason"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textAppearance="@style/Atrium.Inline"
                    android:textStyle="italic"
                    android:textColor="@color/atrium_dim"
                    tools:text="Repeated weakness across games -> structural change" />
            </LinearLayout>
        </ai.chesscoach.app.AtriumCardView>

        <View
            android:id="@+id/coachPlanDivider"
            android:layout_width="match_parent"
            android:layout_height="@dimen/atrium_hairline_thickness"
            android:layout_marginStart="@dimen/atrium_space_24"
            android:layout_marginEnd="@dimen/atrium_space_24"
            android:layout_marginTop="@dimen/atrium_space_16"
            android:layout_marginBottom="@dimen/atrium_space_16"
            android:background="@color/atrium_hairline"
            android:visibility="gone" />

        <!-- TRAINING FOCUS. -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textAppearance="@style/Atrium.Kicker"
            android:text="Training focus"
            android:paddingStart="@dimen/atrium_space_24"
            android:paddingEnd="@dimen/atrium_space_24"
            android:paddingBottom="@dimen/atrium_space_8" />

        <LinearLayout
            android:id="@+id/recommendationsList"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="@dimen/atrium_space_24"
            android:paddingEnd="@dimen/atrium_space_24" />

        <TextView
            android:id="@+id/txtNoRecommendations"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textAppearance="@style/Atrium.Inline"
            android:textStyle="italic"
            android:textColor="@color/atrium_dim"
            android:text="Play more games to unlock personalised recommendations."
            android:paddingStart="@dimen/atrium_space_24"
            android:paddingEnd="@dimen/atrium_space_24"
            android:paddingBottom="@dimen/atrium_space_16"
            android:visibility="gone" />

        <!-- Error state. -->
        <TextView
            android:id="@+id/txtDashboardError"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textAppearance="@style/Atrium.Inline"
            android:textStyle="italic"
            android:textColor="@color/atrium_dim"
            android:text="Could not load dashboard. Check your connection."
            android:gravity="center"
            android:paddingStart="@dimen/atrium_space_24"
            android:paddingEnd="@dimen/atrium_space_24"
            android:paddingTop="@dimen/atrium_space_32"
            android:paddingBottom="@dimen/atrium_space_32"
            android:visibility="gone" />

    </LinearLayout>

</ScrollView>
