<?xml version="1.0" encoding="utf-8"?>
<!--
    Cereveon · Atrium · Game history.

    Closely related to the "Recent games list" mentioned under Atrium
    handoff screen #9 (Profile / stats): "compact rows, mono date +
    result + rating delta".  This sheet is the standalone version
    of that list, opened from the drawer.

    Top → bottom:
      1.  Drag handle.
      2.  AtriumChapterHeaderView — "GAMES" / "Recent".
      3.  Optional rating sparkline (visible only when ≥2 games
          carry a rating_after).
      4.  Scrollable history list — rows built programmatically by
          GameHistoryBottomSheet.buildGameRow / buildDivider.
      5.  Empty / error state (txtHistoryEmpty).

    Preserved IDs (every GameHistoryBottomSheet.kt findViewById
    resolves unchanged): ratingSparkline, historyList, txtHistoryEmpty.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_atrium_gradient"
    android:paddingBottom="@dimen/atrium_space_24">

    <!-- Drag handle. -->
    <View
        android:layout_width="40dp"
        android:layout_height="3dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="@dimen/atrium_space_8"
        android:layout_marginBottom="@dimen/atrium_space_8"
        android:background="@color/atrium_hairline_strong" />

    <!-- Chapter header. -->
    <ai.chesscoach.app.AtriumChapterHeaderView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:atriumKicker="Games"
        app:atriumTitle="Recent" />

    <!-- Source filter — All / In-app / Lichess.  Hard-edged Atrium
         chips; selection is toggled in GameHistoryBottomSheet (text
         colour + chip background). -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginStart="@dimen/atrium_space_24"
        android:layout_marginEnd="@dimen/atrium_space_24"
        android:layout_marginTop="@dimen/atrium_space_8"
        android:baselineAligned="false">

        <TextView
            android:id="@+id/filterAll"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginEnd="@dimen/atrium_space_8"
            android:gravity="center"
            android:fontFamily="monospace"
            android:textSize="11sp"
            android:letterSpacing="0.08"
            android:paddingTop="@dimen/atrium_space_8"
            android:paddingBottom="@dimen/atrium_space_8"
            android:text="ALL" />

        <TextView
            android:id="@+id/filterApp"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginEnd="@dimen/atrium_space_8"
            android:gravity="center"
            android:fontFamily="monospace"
            android:textSize="11sp"
            android:letterSpacing="0.08"
            android:paddingTop="@dimen/atrium_space_8"
            android:paddingBottom="@dimen/atrium_space_8"
            android:text="IN-APP" />

        <TextView
            android:id="@+id/filterLichess"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:fontFamily="monospace"
            android:textSize="11sp"
            android:letterSpacing="0.08"
            android:paddingTop="@dimen/atrium_space_8"
            android:paddingBottom="@dimen/atrium_space_8"
            android:text="LICHESS" />

    </LinearLayout>

    <!-- Rating sparkline trend (≥2 games required). -->
    <ai.chesscoach.app.RatingSparklineView
        android:id="@+id/ratingSparkline"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:layout_marginStart="@dimen/atrium_space_24"
        android:layout_marginEnd="@dimen/atrium_space_24"
        android:layout_marginTop="@dimen/atrium_space_8"
        android:layout_marginBottom="@dimen/atrium_space_4"
        android:visibility="gone"
        tools:visibility="visible" />

    <!-- Scrollable history list.  NestedScrollView, NOT a plain ScrollView:
         BottomSheetBehavior only coordinates drags with a nested-scrolling
         child, so with ScrollView a downward finger drag (scrolling back UP
         through a long game list) dismissed the sheet mid-scroll — the same
         bug fixed on the review sheet in PR #399.  wrap_content (was a fixed
         400dp) so short lists don't trail a dead void and long ones use the
         sheet's full height. -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <LinearLayout
            android:id="@+id/historyList"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="@dimen/atrium_space_24"
            android:paddingEnd="@dimen/atrium_space_24"
            android:paddingTop="@dimen/atrium_space_8" />

    </androidx.core.widget.NestedScrollView>

    <!-- Empty / error state. -->
    <TextView
        android:id="@+id/txtHistoryEmpty"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textAppearance="@style/Atrium.Body.Italic"
        android:textColor="@color/atrium_dim"
        android:text="No games recorded yet."
        android:gravity="center"
        android:paddingTop="@dimen/atrium_space_32"
        android:paddingBottom="@dimen/atrium_space_32"
        android:visibility="gone" />

</LinearLayout>
