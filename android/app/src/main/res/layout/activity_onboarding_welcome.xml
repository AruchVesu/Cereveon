<?xml version="1.0" encoding="utf-8"?>
<!--
    Cereveon · Atrium · Onboarding · Welcome (handoff step 1 of 3).

    First screen the user sees after registration succeeds.  Pure
    informational — establishes what the app is about before
    OnboardingActivity (step 2/3) asks them to calibrate.

    Top → bottom:
      1.  Centered cyan kicker "CEREVEON · STEP 1 OF 3"
      2.  Italic display title "A coach who learns from you."
      3.  Italic muted subtitle (paragraph)
      4.  ✦ ornament rule
      5.  3 ✦-bulleted hooks (what the user gets)
      6.  Footer — single primary "Begin" button

    No Back button — the user is already authenticated, and
    LoginActivity's launchPostAuth would just bounce them back here
    until [PREF_ONBOARDING_COMPLETED] is true (same trap-avoidance
    rationale as OnboardingActivity).
-->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_atrium_gradient"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:paddingStart="@dimen/atrium_space_24"
        android:paddingEnd="@dimen/atrium_space_24"
        android:paddingTop="@dimen/atrium_space_44"
        android:paddingBottom="@dimen/atrium_space_24">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/atrium_space_32"
            android:textAppearance="@style/Atrium.Kicker.Cyan"
            android:text="Cereveon · Step 1 of 3" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/atrium_space_12"
            android:fontFamily="@font/cormorant_garamond"
            android:textStyle="italic"
            android:textColor="@color/atrium_ink"
            android:textSize="36sp"
            android:lineSpacingMultiplier="1.05"
            android:gravity="center_horizontal"
            android:text="A coach who learns from you." />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/atrium_space_12"
            android:fontFamily="@font/cormorant_garamond"
            android:textStyle="italic"
            android:textColor="@color/atrium_muted"
            android:textSize="16sp"
            android:lineSpacingMultiplier="1.4"
            android:gravity="center_horizontal"
            android:maxWidth="320dp"
            android:text="Cereveon studies how you play and adapts the opponent — every game tightens the calibration so the work is always at the right edge of your skill." />

        <!-- ✦ ornament rule. -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/atrium_space_24"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <View
                android:layout_width="0dp"
                android:layout_height="@dimen/atrium_hairline_thickness"
                android:layout_weight="1"
                android:background="@color/atrium_hairline_strong" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/atrium_space_8"
                android:layout_marginEnd="@dimen/atrium_space_8"
                android:fontFamily="@font/cormorant_garamond"
                android:textColor="@color/atrium_muted"
                android:textSize="14sp"
                android:text="✦" />

            <View
                android:layout_width="0dp"
                android:layout_height="@dimen/atrium_hairline_thickness"
                android:layout_weight="1"
                android:background="@color/atrium_hairline_strong" />

        </LinearLayout>

        <!-- Bullets — same item primitive the paywall uses. -->
        <LinearLayout
            android:id="@+id/onboardingWelcomeBullets"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="@dimen/atrium_space_16"
            android:paddingStart="@dimen/atrium_space_8"
            android:paddingEnd="@dimen/atrium_space_8" />

        <Space
            android:layout_width="match_parent"
            android:layout_height="@dimen/atrium_space_44" />

        <Button
            android:id="@+id/btnOnboardingWelcomeBegin"
            style="@style/Atrium.Button.Primary"
            android:layout_width="match_parent"
            android:layout_height="@dimen/atrium_tap_target"
            android:layout_marginTop="@dimen/atrium_space_16"
            android:text="Begin" />

    </LinearLayout>

</ScrollView>
