<?xml version="1.0" encoding="utf-8"?>
<!--
    Cereveon · Atrium · Study-plan week overview (study-plan phase 2b).

    Launched from the TodaysDrillCard's button on HomeActivity.  Renders
    the whole week at a glance — the aggregate-weakness focus, the coach
    verdict, and the three spaced-repetition days (day 0 / 3 / 7) each
    marked Today / Done / Locked — with a primary CTA that launches the
    existing TodaysDrillBottomSheet for the currently-due puzzle.

    Pure renderer: HomeActivity passes the already-fetched
    CoachPlanResponse (as JSON) so this sheet does no network I/O.  The
    "Start today's drill" CTA dismisses this sheet and shows the drill,
    so only one sheet is visible at a time and there is no stale-overview
    refresh problem — reopening always renders fresh state from Home's
    next /coach/plan/today poll.

    Top to bottom:
      1.  Drag handle.
      2.  Kicker — "This week" (cyan accent).
      3.  Focus title — the aggregate weakness ("Tactics"), Cormorant italic.
      4.  Verdict — the LLM coach note (hidden when blank).
      5.  Progress kicker — "Day N of 3".
      6.  Three day rows — label (Replay / Practice) + status (Today / Done / Locked).
      7.  Primary CTA — "Start today's drill" (hidden when nothing is due).
      8.  Footer — "Close" secondary action.

    IDs consumed by StudyPlanOverviewBottomSheet.kt:
      overviewKicker, overviewFocus, overviewVerdict, overviewProgress,
      overviewDay1Label/Status, overviewDay2Label/Status,
      overviewDay3Label/Status, overviewStartButton, overviewCloseButton.
-->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_atrium_gradient"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="@dimen/atrium_space_24"
        android:paddingEnd="@dimen/atrium_space_24"
        android:paddingTop="@dimen/atrium_space_16"
        android:paddingBottom="@dimen/atrium_space_24">

        <View
            android:layout_width="36dp"
            android:layout_height="4dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="@dimen/atrium_space_12"
            android:background="@color/atrium_hairline" />

        <TextView
            android:id="@+id/overviewKicker"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textAppearance="@style/Atrium.Kicker.Cyan"
            android:text="This week" />

        <TextView
            android:id="@+id/overviewFocus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/atrium_space_4"
            android:fontFamily="@font/cormorant_garamond"
            android:textStyle="italic"
            android:textColor="@color/atrium_ink"
            android:textSize="28sp"
            android:lineSpacingMultiplier="1.05"
            tools:text="Tactics" />

        <TextView
            android:id="@+id/overviewVerdict"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/atrium_space_12"
            android:textColor="@color/atrium_muted"
            android:textSize="14sp"
            android:lineSpacingMultiplier="1.25"
            android:text=""
            tools:text="King safety has cost you across several recent games — this week drills the idea so the pattern stops repeating." />

        <TextView
            android:id="@+id/overviewProgress"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/atrium_space_20"
            android:textAppearance="@style/Atrium.Kicker"
            tools:text="Day 2 of 3" />

        <!-- Day rows.  Each is label (weight 1) + status (end). -->
        <LinearLayout
            android:id="@+id/overviewDay1Row"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="@dimen/atrium_space_12"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/overviewDay1Label"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textColor="@color/atrium_ink"
                android:textSize="16sp"
                tools:text="Day 1 · Replay your mistake" />

            <TextView
                android:id="@+id/overviewDay1Status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/atrium_space_8"
                android:textSize="14sp"
                tools:text="Done" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/overviewDay2Row"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="@dimen/atrium_space_16"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/overviewDay2Label"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textColor="@color/atrium_ink"
                android:textSize="16sp"
                tools:text="Day 2 · Practice" />

            <TextView
                android:id="@+id/overviewDay2Status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/atrium_space_8"
                android:textSize="14sp"
                tools:text="Today" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/overviewDay3Row"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="@dimen/atrium_space_16"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/overviewDay3Label"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textColor="@color/atrium_ink"
                android:textSize="16sp"
                tools:text="Day 3 · Practice" />

            <TextView
                android:id="@+id/overviewDay3Status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/atrium_space_8"
                android:textSize="14sp"
                tools:text="Locked" />

        </LinearLayout>

        <Button
            android:id="@+id/overviewStartButton"
            style="@style/Atrium.Button.Primary"
            android:layout_width="match_parent"
            android:layout_height="@dimen/atrium_tap_target"
            android:layout_marginTop="@dimen/atrium_space_24"
            android:text="Start today's drill" />

        <Button
            android:id="@+id/overviewCloseButton"
            style="@style/Atrium.Button.Secondary"
            android:layout_width="match_parent"
            android:layout_height="@dimen/atrium_tap_target"
            android:layout_marginTop="@dimen/atrium_space_12"
            android:text="Close" />

    </LinearLayout>

</ScrollView>
