<?xml version="1.0" encoding="utf-8"?>
<!--
    Cereveon · Atrium · Lichess Connect bottom sheet.

    Two visual states bound from LichessConnectBottomSheet.kt:
      1.  Not linked    — intro copy + "Connect with Lichess" primary
                          button (opens the OAuth consent screen; no
                          username is typed — ownership is proven).
      2.  Linked        — status block (handle, calibration banner,
                          counts) + "Import games" + "Unlink".

    Both blocks live in the same layout; the Fragment toggles
    visibility on the parent groups (groupNotLinked / groupLinked)
    based on LichessConnectViewModel.UiState.

    All styles reuse existing Atrium primitives — no new widgets.
-->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_atrium_gradient"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="@dimen/atrium_space_44">

        <!-- Drag handle. -->
        <View
            android:layout_width="40dp"
            android:layout_height="3dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="@dimen/atrium_space_8"
            android:layout_marginBottom="@dimen/atrium_space_8"
            android:background="@color/atrium_hairline_strong" />

        <!-- Chapter header. -->
        <com.cereveon.myapp.AtriumChapterHeaderView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:atriumKicker="Integrations"
            app:atriumTitle="Lichess" />

        <!-- ── Loading overlay (centred spinner above whichever block is visible). -->
        <ProgressBar
            android:id="@+id/lichessLoadingSpinner"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="@dimen/atrium_space_16"
            android:layout_marginBottom="@dimen/atrium_space_8"
            android:indeterminateTint="@color/atrium_accent_cyan"
            android:visibility="gone"
            tools:visibility="visible" />

        <!-- ╔═══════════════════════════════════════════════════════════╗ -->
        <!-- ║  Not-linked block                                        ║ -->
        <!-- ╚═══════════════════════════════════════════════════════════╝ -->
        <LinearLayout
            android:id="@+id/groupNotLinked"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone"
            tools:visibility="visible">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingStart="@dimen/atrium_space_24"
                android:paddingEnd="@dimen/atrium_space_24"
                android:paddingTop="@dimen/atrium_space_8"
                android:paddingBottom="@dimen/atrium_space_16"
                android:fontFamily="@font/inter"
                android:textSize="14sp"
                android:textColor="@color/atrium_muted"
                android:text="@string/lichess_connect_intro" />

            <Button
                android:id="@+id/btnLichessLink"
                style="@style/Atrium.Button.Primary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/atrium_space_24"
                android:layout_marginEnd="@dimen/atrium_space_24"
                android:text="@string/lichess_link_button_label" />

        </LinearLayout>

        <!-- ╔═══════════════════════════════════════════════════════════╗ -->
        <!-- ║  Linked block                                            ║ -->
        <!-- ╚═══════════════════════════════════════════════════════════╝ -->
        <LinearLayout
            android:id="@+id/groupLinked"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone"
            tools:visibility="visible">

            <!-- "Linked as" kicker + handle. -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textAppearance="@style/Atrium.Kicker"
                android:text="@string/lichess_linked_as_kicker"
                android:paddingStart="@dimen/atrium_space_24"
                android:paddingEnd="@dimen/atrium_space_24"
                android:paddingTop="@dimen/atrium_space_16"
                android:paddingBottom="@dimen/atrium_space_4" />

            <TextView
                android:id="@+id/lichessLinkedHandle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingStart="@dimen/atrium_space_24"
                android:paddingEnd="@dimen/atrium_space_24"
                android:paddingBottom="@dimen/atrium_space_8"
                android:fontFamily="@font/cormorant_garamond"
                android:textStyle="italic"
                android:textSize="22sp"
                android:textColor="@color/atrium_accent_cyan"
                android:text="—"
                tools:text="thibault" />

            <!-- Reconnect notice — visible only when GET /lichess/status
                 reports disconnected=true (the linked account 404'd on
                 import: closed or renamed).  The Fragment also reveals
                 the username form below so the user can reconnect this
                 account or link a different one; imported games stay
                 either way (server contract).  Amber = warning accent,
                 same semantic as the Unlink button. -->
            <TextView
                android:id="@+id/lichessReconnectNotice"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/atrium_space_24"
                android:layout_marginEnd="@dimen/atrium_space_24"
                android:layout_marginBottom="@dimen/atrium_space_8"
                android:padding="@dimen/atrium_space_12"
                android:background="@color/atrium_hairline"
                android:fontFamily="@font/inter"
                android:textSize="13sp"
                android:textColor="@color/atrium_accent_amber"
                android:text="@string/lichess_reconnect_notice"
                android:visibility="gone"
                tools:visibility="visible" />

            <!-- One-shot calibration banner (shown only on the post-link transition). -->
            <TextView
                android:id="@+id/lichessCalibrationBanner"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/atrium_space_24"
                android:layout_marginEnd="@dimen/atrium_space_24"
                android:layout_marginTop="@dimen/atrium_space_8"
                android:layout_marginBottom="@dimen/atrium_space_8"
                android:padding="@dimen/atrium_space_12"
                android:background="@color/atrium_hairline"
                android:fontFamily="@font/inter"
                android:textSize="13sp"
                android:textColor="@color/atrium_ink"
                android:visibility="gone"
                tools:visibility="visible"
                tools:text="Calibrated from your Lichess rapid (894 games)." />

            <View
                style="@style/Atrium.SettingsDivider"
                android:layout_marginTop="@dimen/atrium_space_8" />

            <!-- Imported games count row. -->
            <LinearLayout
                style="@style/Atrium.SettingsRow.Trailing"
                android:clickable="false"
                android:focusable="false">

                <TextView
                    style="@style/Atrium.SettingsRow.Title"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:text="@string/lichess_imported_label" />

                <TextView
                    android:id="@+id/lichessImportedCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/cormorant_garamond"
                    android:textStyle="italic"
                    android:textSize="17sp"
                    android:textColor="@color/atrium_accent_cyan"
                    android:layout_marginEnd="@dimen/atrium_space_12"
                    android:text="0"
                    tools:text="5" />

            </LinearLayout>

            <View style="@style/Atrium.SettingsDivider" />

            <!-- Last imported timestamp row. -->
            <LinearLayout
                style="@style/Atrium.SettingsRow.Trailing"
                android:clickable="false"
                android:focusable="false">

                <TextView
                    style="@style/Atrium.SettingsRow.Title"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:text="@string/lichess_last_synced_label" />

                <TextView
                    android:id="@+id/lichessLastSyncedValue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/inter"
                    android:textStyle="italic"
                    android:textSize="13sp"
                    android:textColor="@color/atrium_muted"
                    android:layout_marginEnd="@dimen/atrium_space_12"
                    android:text="@string/lichess_never_synced"
                    tools:text="2026-05-13" />

            </LinearLayout>

            <View
                style="@style/Atrium.SettingsDivider"
                android:layout_marginBottom="@dimen/atrium_space_16" />

            <!-- Determinate import-progress block.  Visible ONLY while the
                 ViewModel is in UiState.Importing — replaces the "Import games"
                 button so the user sees live progress instead of a stale
                 button.  The denominator is the request cap (target_max_games);
                 we don't know the true total games until the stream ends,
                 hence the "of up to N" phrasing in the caption.  Tint matches
                 the rest of Atrium (accent_cyan for active, hairline for the
                 background track). -->
            <LinearLayout
                android:id="@+id/lichessImportProgressBlock"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/atrium_space_24"
                android:layout_marginEnd="@dimen/atrium_space_24"
                android:layout_marginBottom="@dimen/atrium_space_16"
                android:orientation="vertical"
                android:visibility="gone"
                tools:visibility="visible">

                <ProgressBar
                    android:id="@+id/lichessImportProgressBar"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:progressTint="@color/atrium_accent_cyan"
                    android:progressBackgroundTint="@color/atrium_hairline"
                    android:indeterminate="false"
                    android:max="100"
                    android:progress="0"
                    tools:progress="40" />

                <TextView
                    android:id="@+id/lichessImportProgressCaption"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/atrium_space_8"
                    android:fontFamily="@font/inter"
                    android:textSize="13sp"
                    android:textColor="@color/atrium_muted"
                    android:text=""
                    tools:text="Imported 5 of up to 50" />

            </LinearLayout>

            <Button
                android:id="@+id/btnLichessImport"
                style="@style/Atrium.Button.Primary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/atrium_space_24"
                android:layout_marginEnd="@dimen/atrium_space_24"
                android:text="@string/lichess_import_button_label" />

            <Button
                android:id="@+id/btnLichessUnlink"
                style="@style/Atrium.Button.Secondary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/atrium_space_24"
                android:layout_marginEnd="@dimen/atrium_space_24"
                android:layout_marginTop="@dimen/atrium_space_8"
                android:textColor="@color/atrium_accent_amber"
                android:text="@string/lichess_unlink_button_label" />

        </LinearLayout>

    </LinearLayout>

</ScrollView>
